@using NEOCIO.Umbraco.Core.Extensions
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<BlockGridItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;
    var carouselId = "carousel-" + Guid.NewGuid().ToString("N").Substring(0, 8);

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();
    var items = content.Value<BlockListModel>("items");
}


<div class="carousel @blockClasses" id="@carouselId" data-carousel tabindex="0">
    <div class="carousel__viewport">
        <div class="carousel__track">
            @if (items.Any())
            {
                var index = 0;
                foreach (var item in items)
                {
                    var carouselItem = item;
                    var slideId = $"{carouselId}-slide-{index}";
                    var slideLabel = $"Slide {index + 1} of {items.Count()}";
                    <div id="@slideId" class="carousel__slide @(index == 0 ? "carousel__slide--active" : "")" data-slide="@index" role="group" aria-roledescription="slide" aria-label="@slideLabel" aria-hidden="@(index == 0 ? "false" : "true")">
                        @await Component.InvokeAsync("CarouselItem", new { model = item })
                    </div>
                    index++;
                }
            }
        </div>
    </div>

    @if (items.Any() && items.Count() > 1)
    {
        <div class="visually-hidden" aria-live="polite" id="@(carouselId)-status" data-carousel-status></div>
        <div class="carousel__controls">
            <button class="carousel__button carousel__button--prev" aria-label="Previous slide">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>

            <button class="carousel__button carousel__button--play-pause" aria-label="Pause carousel" aria-pressed="false">
                <svg class="carousel__icon--play" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
                    <path d="M8 5V19L19 12L8 5Z" fill="currentColor"/>
                </svg>
                <svg class="carousel__icon--pause" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 4H10V20H6V4Z" fill="currentColor"/>
                    <path d="M14 4H18V20H14V4Z" fill="currentColor"/>
                </svg>
            </button>

            <button class="carousel__button carousel__button--next" aria-label="Next slide">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>

        <div class="carousel__indicators" role="tablist" aria-label="Carousel slides">
            @for (var i = 0; i < items.Count(); i++)
            {
                var indicatorControls = $"{carouselId}-slide-{i}";
                <button class="carousel__indicator @(i == 0 ? "carousel__indicator--active" : "")"
                        data-slide-to="@i"
                        aria-controls="@indicatorControls"
                        aria-pressed="@(i == 0 ? "true" : "false")"
                        aria-label="Go to slide @(i + 1)">
                </button>
            }
        </div>
    }

</div>

<script>
    (function() {
        const carousel = document.getElementById('@carouselId');
        if (!carousel) return;

        const track = carousel.querySelector('.carousel__track');
        const slides = carousel.querySelectorAll('.carousel__slide');

        if (slides.length <= 1) return;

        const prevButton = carousel.querySelector('.carousel__button--prev');
        const nextButton = carousel.querySelector('.carousel__button--next');
        const playPauseButton = carousel.querySelector('.carousel__button--play-pause');
        const playIcon = playPauseButton && playPauseButton.querySelector('.carousel__icon--play');
        const pauseIcon = playPauseButton && playPauseButton.querySelector('.carousel__icon--pause');
        const indicators = carousel.querySelectorAll('.carousel__indicator');
        const statusEl = carousel.querySelector('[data-carousel-status]');

        let currentSlide = 0;
        let isPlaying = false;
        let isUserPaused = false;
        let autoplayInterval = null;
        const autoplayDelay = 3000;
        const initialDelay = 2000;
        const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function goToSlide(index) {
            slides[currentSlide].classList.remove('carousel__slide--active');
            indicators[currentSlide].classList.remove('carousel__indicator--active');
            indicators[currentSlide].setAttribute('aria-pressed', 'false');

            currentSlide = (index + slides.length) % slides.length;

            slides[currentSlide].classList.add('carousel__slide--active');
            indicators[currentSlide].classList.add('carousel__indicator--active');
            indicators[currentSlide].setAttribute('aria-pressed', 'true');

            // update aria-hidden on slides
            slides.forEach((s, i) => s.setAttribute('aria-hidden', i === currentSlide ? 'false' : 'true'));

            // announce slide change
            if (statusEl) {
                // try to find a heading inside the slide to provide context
                const slideEl = slides[currentSlide];
                const heading = slideEl.querySelector('h1, h2, h3, h4, h5');
                const title = heading ? heading.textContent.trim() : '';
                statusEl.textContent = `Slide ${currentSlide + 1} of ${slides.length}` + (title ? `: ${title}` : '');
            }

            const offset = -currentSlide * 100;
            track.style.transform = `translateX(${offset}%)`;
        }

        function nextSlide() {
            goToSlide(currentSlide + 1);
        }

        function prevSlide() {
            goToSlide(currentSlide - 1);
        }

        function startAutoplay() {
            if (isPlaying) return;
            isPlaying = true;
            playIcon.style.display = 'none';
            pauseIcon.style.display = 'block';
            if (playPauseButton) {
                playPauseButton.setAttribute('aria-label', 'Pause carousel');
                playPauseButton.setAttribute('aria-pressed', 'true');
            }
            autoplayInterval = setInterval(nextSlide, autoplayDelay);
        }

        function stopAutoplay() {
            if (!isPlaying) return;
            isPlaying = false;
            playIcon.style.display = 'block';
            pauseIcon.style.display = 'none';
            if (playPauseButton) {
                playPauseButton.setAttribute('aria-label', 'Play carousel');
                playPauseButton.setAttribute('aria-pressed', 'false');
            }
            clearInterval(autoplayInterval);
            autoplayInterval = null;
        }

        prevButton.addEventListener('click',
            function() {
                prevSlide();
                if (isPlaying && !isUserPaused) {
                    clearInterval(autoplayInterval);
                    autoplayInterval = setInterval(nextSlide, autoplayDelay);
                }
            });

        nextButton.addEventListener('click',
            function() {
                nextSlide();
                if (isPlaying && !isUserPaused) {
                    clearInterval(autoplayInterval);
                    autoplayInterval = setInterval(nextSlide, autoplayDelay);
                }
            });

        playPauseButton.addEventListener('click',
            function() {
                if (isPlaying) {
                    isUserPaused = true;
                    stopAutoplay();
                } else {
                    isUserPaused = false;
                    startAutoplay();
                }
            });

        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click',
                function() {
                    goToSlide(index);
                    if (isPlaying && !isUserPaused) {
                        clearInterval(autoplayInterval);
                        autoplayInterval = setInterval(nextSlide, autoplayDelay);
                    }
                });
        });

        carousel.addEventListener('mouseenter',
            function() {
                if (isPlaying && !isUserPaused) {
                    clearInterval(autoplayInterval);
                    autoplayInterval = null;
                }
            });

        carousel.addEventListener('mouseleave',
            function() {
                if (isPlaying && !isUserPaused && autoplayInterval === null) {
                    autoplayInterval = setInterval(nextSlide, autoplayDelay);
                }
            });

        // Keyboard support when the carousel container has focus
        carousel.addEventListener('keydown',
            function(e) {
                // Only handle keys when the carousel container itself is focused
                if (document.activeElement !== carousel) return;

                switch (e.key) {
                case 'ArrowRight':
                case 'Right':
                    e.preventDefault();
                    nextSlide();
                    if (isPlaying && !isUserPaused) {
                        clearInterval(autoplayInterval);
                        autoplayInterval = setInterval(nextSlide, autoplayDelay);
                    }
                    break;
                case 'ArrowLeft':
                case 'Left':
                    e.preventDefault();
                    prevSlide();
                    if (isPlaying && !isUserPaused) {
                        clearInterval(autoplayInterval);
                        autoplayInterval = setInterval(nextSlide, autoplayDelay);
                    }
                    break;
                case 'Home':
                    e.preventDefault();
                    goToSlide(0);
                    break;
                case 'End':
                    e.preventDefault();
                    goToSlide(slides.length - 1);
                    break;
                case ' ': // Space toggles play/pause
                case 'Spacebar':
                    e.preventDefault();
                    if (playPauseButton) {
                        if (isPlaying) {
                            isUserPaused = true;
                            stopAutoplay();
                        } else {
                            isUserPaused = false;
                            startAutoplay();
                        }
                    }
                    break;
                case 'Enter':
                    // Enter also toggles play/pause when focused
                    e.preventDefault();
                    if (playPauseButton) {
                        if (isPlaying) {
                            isUserPaused = true;
                            stopAutoplay();
                        } else {
                            isUserPaused = false;
                            startAutoplay();
                        }
                    }
                    break;
                }
            });

        setTimeout(function() {
                playIcon.style.display = 'none';
                pauseIcon.style.display = 'block';
                startAutoplay();
            },
            initialDelay);
    })();
</script>