@using System.Text
@using Umbraco.Cms.Core
@using UmbHost.Tables.Models
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var siteSettings = Umbraco.AssignedContentItem?.Root()?.FirstChild();
    var theme = siteSettings?.Value<string>("theme")?.ToLowerInvariant() ?? "blue";

    var table = content.Value<TableModel>("tableContent");

    var headers = new List<string>();

    if (table != null && table.Rows.Any() && table.UseFirstRowAsHeader)
    {
        headers = table.Rows.First().Cells.Select(c => c.Value?.ToString() ?? "").ToList();
    }

    var tableCSS = new StringBuilder();

    if (content.Value<bool?>("stripedTable") == true)
    {
        tableCSS.Append(" basic-table-striped");
    }

    var tablePicked = content.Value<Umbraco.Cms.Core.PropertyEditors.ValueConverters.ColorPickerValueConverter.PickedColor>("tableColorScheme");
    var tableColorScheme = tablePicked?.Color ?? "var(--theme-primary)";

    var styles = $@"
        --basic-table__color-scheme: {tableColorScheme};
	";

    var blockClasses = BuildBlockSettingsClasses(Model.Settings);

    var tableId = "basic-table-" + Guid.NewGuid().ToString("N").Substring(0, 8);
    var captionId = "basic-table-caption-" + Guid.NewGuid().ToString("N").Substring(0, 8);

    static string BuildBlockSettingsClasses(IPublishedElement? settings)
    {
        if (settings is null)
        {
            return string.Empty;
        }

        var marginTop = settings.Value<string>("marginTop");
        var marginBottom = settings.Value<string>("marginBottom");
        var marginRight = settings.Value<string>("marginRight");
        var marginLeft = settings.Value<string>("marginLeft");

        var paddingTop = settings.Value<string>("paddingTop");
        var paddingBottom = settings.Value<string>("paddingBottom");
        var paddingRight = settings.Value<string>("paddingRight");
        var paddingLeft = settings.Value<string>("paddingLeft");

        var classes = new StringBuilder();
        classes.Append($" {MapSpacingClass(marginTop, "mt")}");
        classes.Append($" {MapSpacingClass(marginBottom, "mb")}");
        classes.Append($" {MapSpacingClass(marginRight, "me")}");
        classes.Append($" {MapSpacingClass(marginLeft, "ms")}");
        classes.Append($" {MapSpacingClass(paddingTop, "pt")}");
        classes.Append($" {MapSpacingClass(paddingBottom, "pb")}");
        classes.Append($" {MapSpacingClass(paddingRight, "pe")}");
        classes.Append($" {MapSpacingClass(paddingLeft, "ps")}");

        return classes.ToString();
    }

    static string MapSpacingClass(string? value, string prefix)
        => value switch
        {
            "Small" => $"{prefix}-3",
            "Medium" => $"{prefix}-4",
            "Large" => $"{prefix}-5",
            "XL" => $"{prefix}-6",
            _ => $"{prefix}-0"
        };
}

@if (table != null && table.Rows.Any())
{
    <table id="@tableId" class="basic-table @tableCSS.ToString() @blockClasses" style="@styles" @(string.IsNullOrWhiteSpace(content.Value<string>("caption")) ? string.Empty : $"aria-describedby=\"{captionId}\"")>

        @* Caption should be first child of table for accessibility *@
        @if (!string.IsNullOrWhiteSpace(content.Value<string>("caption")))
        {
            <caption id="@captionId">@Html.Raw(content.Value<string>("caption") ?? string.Empty)</caption>
        }

        @if (table.UseFirstRowAsHeader && table.Rows.Any())
        {
            <thead>
            <tr>
                @foreach (var cell in table.Rows.First().Cells)
                {
                    <th scope="col">@Html.Raw(cell.Value)</th>
                }
            </tr>
            </thead>
        }
        <tbody>
        @foreach (var row in table.UseFirstRowAsHeader ? table.Rows.Skip(1) : table.Rows)
        {
            <tr>
                @for (var i = 0; i < row.Cells.Count; i++)
                {
                    var cell = row.Cells[i];
                    var headerText = headers.Count > i ? headers[i] : "";

                    if (table.UseFirstColumnAsHeader && i == 0)
                    {
                        <th scope="row">@Html.Raw(cell.Value)</th>
                    }
                    else
                    {
                        <td data-cell="@headerText">@Html.Raw(cell.Value)</td>
                    }
                }
            </tr>
        }
        </tbody>

    </table>
}

<script>
    // Scope enhancement to tables rendered by this component only
    document.querySelectorAll("table.basic-table").forEach(function(table) {
        table.setAttribute("role", "table");
        var caption = table.querySelector(":scope > caption");
        if(caption) caption.setAttribute("role", "caption");
        table.querySelectorAll(":scope > thead, :scope > tfoot, :scope > tbody")
            .forEach(tpart => tpart.setAttribute("role", "rowgroup"));
        Array.from(table.rows).forEach(function(row) {
            row.setAttribute("role", "row");
            Array.from(row.children)
                .forEach(function(cell){
                    var nodeName = cell.nodeName;
                    var scopeAttr = cell.getAttribute('scope');
                    if(nodeName === 'TD') cell.setAttribute('role','cell');
                    else if(scopeAttr === 'row') cell.setAttribute('role','rowheader');
                    else cell.setAttribute('role','columnheader');
                });
        });
    });
</script>
