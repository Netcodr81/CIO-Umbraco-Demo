@using System.Text
@using NEOCIO.Umbraco.Core.Extensions
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var hasIcon = content.Value<MediaWithCrops>("icon") is not null;
    var targetAnchor = content.Value<string>("targetAnchorId") ?? "top";
    var anchorHref = $"#{targetAnchor}";

    // Cache frequently used values to avoid Razor generic parsing issues in markup
    var showDivider = content.Value<bool>("showDivider");
    var dividerColor = content.Value<ColorPickerValueConverter.PickedColor>("dividerColor")?.Color;
    var buttonText = content.Value<string>("buttonText");
    var icon = content.Value<MediaWithCrops>("icon");
    var iconLocation = content.Value<string>("iconLocation");
    var svgAriaHidden = string.IsNullOrWhiteSpace(buttonText) ? "false" : "true";
    var buttonStyle = content.Value<string>("buttonStyle");

    var styles = new StringBuilder();

    if (!string.IsNullOrWhiteSpace(content.Value<string>("minWidth")))
    {
        styles.Append($" min-width:{content.Value<string>("minWidth")}");
    }

    if (!string.IsNullOrWhiteSpace(content.Value<string>("maxWidth")))
    {
        styles.Append($" max-width:{content.Value<string>("maxWidth")}");
    }

    if (!string.IsNullOrWhiteSpace(content.Value<string>("width")))
    {
        styles.Append($" width:{content.Value<string>("width")}");
    }

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    var ariaLabel = string.IsNullOrWhiteSpace(buttonText) ? $"Return to {targetAnchor}" : null;
    var ariaAttr = ariaLabel is null ? string.Empty : $"aria-label=\"{ariaLabel}\"";

    var dividerStyle = showDivider ? (dividerColor is null ? "border-top:1px solid #64748b;padding-top:1.25rem;" : $"border-top:{dividerColor};padding-top:1.25rem;") : string.Empty;
}


<div class="return-to-anchor-btn__container @blockClasses" style="@dividerStyle">
    @switch (buttonStyle)
    {
        case "Primary":
            if (hasIcon)
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()" @Html.Raw(ariaAttr)>
                    @if (iconLocation == "Prepend")
                    {
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                        @buttonText
                    }
                    else
                    {
                        @buttonText
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                    }
                </a>
            }
            else
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()">
                    @buttonText
                </a>
            }

            break;
        case "Secondary":
            if (hasIcon)
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__secondary return-to-anchor-btn__link" style="@styles.ToString()" @Html.Raw(ariaAttr)>
                    @if (iconLocation == "Prepend")
                    {
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                        @buttonText
                    }
                    else
                    {
                        @buttonText
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                    }
                </a>
            }
            else
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__secondary return-to-anchor-btn__link" style="@styles.ToString()">@buttonText</a>
            }

            break;
        case "Outline":
            if (hasIcon)
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__outline return-to-anchor-btn__link" style="@styles.ToString()" @Html.Raw(ariaAttr)>
                    @if (iconLocation == "Prepend")
                    {
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                        @buttonText
                    }
                    else
                    {
                        @buttonText
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                    }
                </a>
            }
            else
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__outline return-to-anchor-btn__link" style="@styles.ToString()">@buttonText</a>
            }

            break;
        default:
            if (hasIcon)
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()" @Html.Raw(ariaAttr)>
                    @if (iconLocation == "Prepend")
                    {
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                        @buttonText
                    }
                    else
                    {
                        @buttonText
                        <inline-svg media-item="@icon" fill="#fff" height="16" width="16" aria-hidden='@svgAriaHidden'/>
                    }
                </a>
            }
            else
            {
                <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()">@buttonText</a>
            }

            break;
    }
</div>

<script>
    (function() {
        document.querySelectorAll('.return-to-anchor-btn__link').forEach(function(link) {
            link.addEventListener('click',
                function(e) {
                    e.preventDefault();

                    var targetId = this.getAttribute('href').substring(1);
                    var targetElement = document.getElementById(targetId);

                    if (targetElement) {
                        var startPosition = window.pageYOffset;
                        var targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset;
                        var distance = targetPosition - startPosition;
                        var duration = 1200; // 1.2 seconds - adjust this for speed (higher = slower)
                        var startTime = null;

                        function easeInOutCubic(t) {
                            return t < 0.5 ? 4 * t * t * t : (t - 1) * (2 * t - 2) * (2 * t - 2) + 1;
                        }

                        function animation(currentTime) {
                            if (startTime === null) startTime = currentTime;
                            var timeElapsed = currentTime - startTime;
                            var progress = Math.min(timeElapsed / duration, 1);
                            var ease = easeInOutCubic(progress);

                            window.scrollTo(0, startPosition + (distance * ease));

                            if (timeElapsed < duration) {
                                requestAnimationFrame(animation);
                            } else {
                                // Update URL hash without jumping
                                history.pushState(null, null, '#' + targetId);
                                // Set focus for accessibility - ensure target is focusable
                                try {
                                    if (!targetElement.hasAttribute('tabindex')) {
                                        targetElement.setAttribute('tabindex', '-1');
                                        // Use preventScroll when available
                                        try {
                                            targetElement.focus({ preventScroll: true });
                                        } catch (err) {
                                            targetElement.focus();
                                        }
                                        targetElement.addEventListener('blur',
                                            function onBlur() {
                                                targetElement.removeAttribute('tabindex');
                                                targetElement.removeEventListener('blur', onBlur);
                                            });
                                    } else {
                                        try {
                                            targetElement.focus({ preventScroll: true });
                                        } catch (err) {
                                            targetElement.focus();
                                        }
                                    }
                                } catch (err) {
                                    // Fallback: attempt to focus without options
                                    try {
                                        targetElement.focus();
                                    } catch (e) {
                                    }
                                }
                            }
                        }

                        requestAnimationFrame(animation);
                    }
                });
        });
    })();
</script>