                    }
                    else
                    {
                        <span class="visually-hidden">@accessibleName</span>
                    }

                    <inline-svg media-item="@(icon)" height="16" width="16" aria-hidden="true"/>
                }
                else
                {
                    @text
                }
            </a>
        }
        else
        {
            <button type="button" class="btn__button btn__primary @blockClasses" style="@styles.ToString()" aria-label="@accessibleName">
                @if (hasIcon && iconLocation == "Prepend")
                {
                    <inline-svg media-item="@(icon)" height="16" width="16" aria-hidden="true"/>
                    @if (hasText)
