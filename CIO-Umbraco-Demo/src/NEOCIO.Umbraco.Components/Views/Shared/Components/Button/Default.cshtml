                        @text
                    }
                    else
                    {
                        <span class="visually-hidden">@accessibleName</span>
                    }

                    <inline-svg media-item="@(icon)" height="16" width="16" aria-hidden="true"/>
                }
                else
                {
                    @text
                }
            </button>
        }

        break;
    case "Secondary":
        if (!string.IsNullOrWhiteSpace(link.Url))
        {
            <a class="btn__button btn__secondary @blockClasses" style="@styles.ToString()" href="@link.Url" target="@(string.IsNullOrWhiteSpace(link.Target) ? null : link.Target)" rel="@(link.Target == "_blank" ? "noopener noreferrer" : null)" aria-label="@accessibleName">
