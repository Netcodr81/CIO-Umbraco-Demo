@using NEOCIO.Umbraco.Core.Extensions
@using Umbraco.Extensions
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var width = !string.IsNullOrWhiteSpace(content.Value<string>("width")) ? content.Value<string>("width") : "100%";
    var height = !string.IsNullOrWhiteSpace(content.Value<string>("height")) ? content.Value<string>("height") : "100%";
    var tabletWidth = !string.IsNullOrWhiteSpace(content.Value<string>("tabletWidth")) ? content.Value<string>("tabletWidth") : "100%";
    var tabletHeight = !string.IsNullOrWhiteSpace(content.Value<string>("tabletHeight")) ? content.Value<string>("tabletHeight") : "100%";
    var mobileWidth = !string.IsNullOrWhiteSpace(content.Value<string>("mobileWidth")) ? content.Value<string>("mobileWidth") : "100%";
    var mobileHeight = !string.IsNullOrWhiteSpace(content.Value<string>("mobileHeight")) ? content.Value<string>("mobileHeight") : "100%";

    var styles = $@"
        --embed__width: {width};
        --embed__height: {height};
        --embed__tablet-width: {tabletWidth};
        --embed__tablet-height: {tabletHeight};
        --embed__mobile-width: {mobileWidth};
        --embed__mobile-height: {mobileHeight};
    ";

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    // Determine accessible title for the iframe. Prefer an explicit Title or Caption if available.
    var iframeTitle = !string.IsNullOrWhiteSpace(content.Value<string>("title")) ? content.Value<string>("title") : (!string.IsNullOrWhiteSpace(content.Value<string>("caption")) ? content.Value<string>("caption") : "Embedded content");

    var embedUrl = content.Value<string>("embedUrl");
}

<div class="embed__container @blockClasses" style="@styles" role="region" aria-label="@iframeTitle">
    @if (string.IsNullOrWhiteSpace(embedUrl))
    {
        <p class="visually-hidden">No embedded content available.</p>
    }
    else
    {
        <iframe
            src="@embedUrl"
            title="@iframeTitle"
            loading="lazy"
            role="document"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
            allowfullscreen
            style="width: 100%; height: 100%; border: 0;">
        </iframe>
    }
</div>
