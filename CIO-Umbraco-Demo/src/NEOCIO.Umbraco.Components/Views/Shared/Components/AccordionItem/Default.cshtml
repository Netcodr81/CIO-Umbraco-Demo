@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem>

@{
    if (Model?.Content is null) return;

    var content = Model.Content; // IPublishedElement
    var uniqueId = "accordionItem-" + Guid.NewGuid().ToString("N").Substring(0, 8);
    var titleId = uniqueId + "-title";

    var title = content.Value<string>("drawerTitle") ?? string.Empty;
    var contentHtml = content.Value<object?>("drawerContent")?.ToString() ?? string.Empty;
}

<section class="accordion-item__container" role="region" aria-labelledby="@titleId">
    <h3 id="@titleId" class="accordion-item__title">@title</h3>
    <div class="accordion-item__content">@Html.Raw(contentHtml)</div>
</section>
