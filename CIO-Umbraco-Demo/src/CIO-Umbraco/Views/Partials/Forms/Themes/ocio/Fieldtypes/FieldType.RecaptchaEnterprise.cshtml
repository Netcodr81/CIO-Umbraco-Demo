@using Microsoft.Extensions.Options
@using Umbraco.Forms.Core.Configuration
@using Umbraco.Forms.Web

@inject IOptionsSnapshot<RecaptchaEnterpriseSettings> Configuration

@model Umbraco.Forms.Web.Models.FieldViewModel
@{
    var siteKey = Configuration.Value.SiteKey;
    var domain = Configuration.Value.Domain.GetDomainName();

    if (!string.IsNullOrEmpty(siteKey))
    {
        @* Google JS reCAPTCHA API and initialization scripts *@
        Html.AddFormThemeScriptFile($"https://{domain}/recaptcha/enterprise.js?render={siteKey}");
        Html.AddFormThemeScriptFile("~/App_Plugins/UmbracoForms/assets/recaptcha.enterprise.init.min.js");

        @* Hidden Field to store token from invisible reCAPTCHA *@
        <input type="hidden" id="@Model.Id" name="g-recaptcha-response" />

        @* Recaptcha config for reference from initialization script *@
        <div class="umbraco-forms-recaptcha-enterprise-config umbraco-forms-hidden"
             data-id="@Model.Id"
             data-site-key="@siteKey"></div>
    }
    else
    {
        <p class="error">ERROR: reCAPTCHA Enterprise is missing the Site Key. Please update the configuration to include a value at: @(Umbraco.Forms.Core.Constants.Configuration.SectionKeys.FieldTypes.RecaptchaEnterprise):SiteKey</p>
    }
}
