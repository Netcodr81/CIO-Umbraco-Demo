@model Umbraco.Forms.Web.Models.FormViewModel

<div class="form-submitted-container">
    <div class="form-submitted-content">
        <div class="form-submitted-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
        </div>

        <h2 class="form-submitted-heading">Thank You!</h2>

        @if (Model.MessageOnSubmitIsHtml)
        {
            <div class="form-submitted-message">
                @Model.GetMessageOnSubmit()
            </div>
        }
        else
        {
            <p class="form-submitted-message">
                @Model.GetMessageOnSubmit()
            </p>
        }

        <div class="form-submitted-actions">
            <a href="/" class="btn-return-home">Return to Home</a>
        </div>
    </div>
</div>

@await Html.PartialAsync("Forms/Themes/default/ScrollToFormScript")

