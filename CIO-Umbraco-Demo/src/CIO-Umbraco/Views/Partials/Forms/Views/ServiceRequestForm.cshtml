@using CIOUmbracoDemo.Controllers
@model CIOUmbracoDemo.Views.Partials.Forms.Models.ServiceRequestFormViewModel

@{
    var formSubmitted = TempData["ServiceRequestFormSuccess"] as bool? ?? false;
}

@if (!formSubmitted)
{
    @using (Html.BeginUmbracoForm<ServiceRequestFormController>("Submit", FormMethod.Post, new { @class = "custom-forms-form", role = "form" }))
    {
        <input type="hidden" asp-for="FormId"/>

        <fieldset>
            <div class="row-fluid">
                <div class="col-md-12">

                    <div class="custom-forms-field">
                        <label for="FirstName" class="custom-forms-label">
                            First Name (required)<span class="custom-forms-indicator">*</span>
                        </label>
                        <input asp-for="FirstName"
                               type="text"
                               id="FirstName"
                               name="FirstName"
                               aria-label="First name"
                               required
                               aria-required="true"
                               class="text @(ViewData.ModelState["FirstName"]?.Errors.Count > 0 ? "input-validation-error" : "")"
                               placeholder="Your first name"/>
                        <span id="FirstName-error" asp-validation-for="FirstName" class="field-validation-error"></span>
                    </div>

                    <div class="custom-forms-field">
                        <label for="LastName" class="custom-forms-label">
                            Last Name (required)<span class="custom-forms-indicator">*</span>
                        </label>
                        <input asp-for="LastName"
                               type="text"
                               id="LastName"
                               name="LastName"
                               aria-label="Last name"
                               required
                               aria-required="true"
                               class="text @(ViewData.ModelState["LastName"]?.Errors.Count > 0 ? "input-validation-error" : "")"
                               placeholder="Your last name"/>
                        <span id="LastName-error" asp-validation-for="LastName" class="field-validation-error"></span>
                    </div>

                    <div class="custom-forms-field">
                        <label for="PhoneNumber" class="custom-forms-label">
                            Phone Number (required)<span class="custom-forms-indicator">*</span>
                        </label>
                        <input asp-for="PhoneNumber"
                               type="tel"
                               id="PhoneNumber"
                               name="PhoneNumber"
                               aria-label="Phone number"
                               required
                               aria-required="true"
                               class="text @(ViewData.ModelState["PhoneNumber"]?.Errors.Count > 0 ? "input-validation-error" : "")"
                               placeholder="Your Phone Number"/>
                        <span id="PhoneNumber-error" asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                    </div>

                    <div class="custom-forms-field">
                        <label for="Email" class="custom-forms-label">
                            Email (required)<span class="custom-forms-indicator">*</span>
                        </label>
                        <input asp-for="Email"
                               type="email"
                               id="Email"
                               name="Email"
                               aria-label="Email"
                               required
                               aria-required="true"
                               class="text @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "input-validation-error" : "")"
                               placeholder="Your Email"/>
                        <span id="Email-error" asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <div class="custom-forms-field">
                        <label for="Agency" class="custom-forms-label">
                            Agency (required)<span class="custom-forms-indicator">*</span>
                        </label>
                        <input asp-for="Agency"
                               type="text"
                               id="Agency"
                               name="Agency"
                               aria-label="Agency"
                               required
                               aria-required="true"
                               class="text @(ViewData.ModelState["Agency"]?.Errors.Count > 0 ? "input-validation-error" : "")"
                               placeholder="Your Agency"/>
                        <span id="Agency-error" asp-validation-for="Agency" class="field-validation-error"></span>
                    </div>

                    <div class="custom-forms-field">
                        <label for="DescriptionServiceRequested" class="custom-forms-label">
                            Message (required)<span class="custom-forms-indicator">*</span>
                        </label>
                        <textarea asp-for="DescriptionServiceRequested"
                                  id="DescriptionServiceRequested"
                                  name="DescriptionServiceRequested"
                                  aria-label="Service request description"
                                  aria-required="true"
                                  class="@(ViewData.ModelState["DescriptionServiceRequested"]?.Errors.Count > 0 ? "input-validation-error" : "")"
                                  placeholder="Your Service Request"
                                  rows="10"></textarea>
                        <span id="DescriptionServiceRequested-error" asp-validation-for="DescriptionServiceRequested" class="field-validation-error"></span>
                    </div>

                </div>
            </div>
        </fieldset>

        <div class="custom-forms-navigation row-fluid">
            <div class="col-md-12">
                <input type="submit"
                       role="button"
                       class="btn primary"
                       value="Submit"
                       aria-label="Submit service request form"/>
                <input type="reset"
                       role="button"
                       class="btn cancel"
                       value="Reset"
                       aria-label="Reset service request form"/>
            </div>
        </div>
    }
}
else
{
    @await Html.PartialAsync("Forms/Views/FormSubmitted", Model.SuccessMessage)
}