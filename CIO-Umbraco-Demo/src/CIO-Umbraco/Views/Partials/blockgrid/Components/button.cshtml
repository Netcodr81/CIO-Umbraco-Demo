@using System.Text
@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockGridItem<ContentModels.Button>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var hasIcon = content.Icon is not null;

    var styles = new StringBuilder();

    if (!string.IsNullOrWhiteSpace(content.MinWidth))
    {
        styles.Append($" min-width:{content.MinWidth}");
    }

    if (!string.IsNullOrWhiteSpace(content.MaxWidth))
    {
        styles.Append($" max-width:{content.MaxWidth}");
    }

    if (!string.IsNullOrWhiteSpace(content.Width))
    {
        styles.Append($" width:{content.Width}");
    }

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();
}

@switch (content.ButtonStyle)
{
    case "Primary":
        if (hasIcon)
        {
            <button class="btn__button btn__primary @blockClasses" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" height="16" width="16"/>
                    @content.Text
                }
                else
                {
                    @content.Text
                    <inline-svg media-item="content.Icon" height="16" width="16"/>
                }
            </button>
        }
        else
        {
            <button class="btn__button btn__primary @blockClasses" style="@styles.ToString()">
                @content.Text
            </button>
        }

        break;
    case "Secondary":
        if (hasIcon)
        {
            <button class="btn__button btn__secondary @blockClasses" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" height="16" width="16"/>
                    @content.Text
                }
                else
                {
                    @content.Text
                    <inline-svg media-item="content.Icon"  height="16" width="16"/>
                }
            </button>
        }
        else
        {
            <button class="btn__button btn__secondary @blockClasses" style="@styles.ToString()">@content.Text</button>
        }

        break;
    case "Outline":
        if (hasIcon)
        {
            <button class="btn__button btn__outline @blockClasses" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon"  height="16" width="16"/>
                    @content.Text
                }
                else
                {
                    @content.Text
                    <inline-svg media-item="content.Icon"  height="16" width="16"/>
                }
            </button>
        }
        else
        {
            <button class="btn__button btn__outline @blockClasses" style="@styles.ToString()">@content.Text</button>
        }

        break;
    default:
        if (hasIcon)
        {
            <button class="btn__button btn__primary @blockClasses" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon"  height="16" width="16"/>
                    @content.Text
                }
                else
                {
                    @content.Text
                    <inline-svg media-item="content.Icon"  height="16" width="16"/>
                }
            </button>
        }
        else
        {
            <button class="btn__button btn__primary @blockClasses" style="@styles.ToString()">@content.Text</button>
        }

        break;
}