@using System.Text
@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockGridItem<ContentModels.Button>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var hasIcon = content.Icon is not null;

    var styles = new StringBuilder();

    if (!string.IsNullOrWhiteSpace(content.MinWidth))
    {
        styles.Append($" min-width:{content.MinWidth}");
    }

    if (!string.IsNullOrWhiteSpace(content.MaxWidth))
    {
        styles.Append($" max-width:{content.MaxWidth}");
    }

    if (!string.IsNullOrWhiteSpace(content.Width))
    {
        styles.Append($" width:{content.Width}");
    }

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    var linkUrl = content?.Link?.Url;
    var linkTarget = content?.Link?.Target;
    var hasText = !string.IsNullOrWhiteSpace(content?.Text);
    var accessibleName = hasText ? content.Text : (content?.Link?.Name ?? content?.Icon?.Name ?? "Button");
}

@switch (content.ButtonStyle)
{
    case "Primary":
        if (!string.IsNullOrWhiteSpace(linkUrl))
        {
            <a class="btn__button btn__primary @blockClasses" style="@styles.ToString()" href="@linkUrl" target="@(string.IsNullOrWhiteSpace(linkTarget) ? null : linkTarget)" rel="@(linkTarget == "_blank" ? "noopener noreferrer" : null)" aria-label="@accessibleName">
                @if (hasIcon && content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" height="16" width="16" aria-hidden="true" />
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                }
                else if (hasIcon && content.IconLocation != "Prepend")
                {
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                    <inline-svg media-item="content.Icon" height="16" width="16" aria-hidden="true" />
                }
                else
                {
                    @content.Text
                }
            </a>
        }
        else
        {
            <button type="button" class="btn__button btn__primary @blockClasses" style="@styles.ToString()" aria-label="@accessibleName">
                @if (hasIcon && content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" height="16" width="16" aria-hidden="true" />
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                }
                else if (hasIcon && content.IconLocation != "Prepend")
                {
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                    <inline-svg media-item="content.Icon" height="16" width="16" aria-hidden="true" />
                }
                else
                {
                    @content.Text
                }
            </button>
        }

        break;
    case "Secondary":
        if (!string.IsNullOrWhiteSpace(linkUrl))
        {
            <a class="btn__button btn__secondary @blockClasses" style="@styles.ToString()" href="@linkUrl" target="@(string.IsNullOrWhiteSpace(linkTarget) ? null : linkTarget)" rel="@(linkTarget == "_blank" ? "noopener noreferrer" : null)" aria-label="@accessibleName">
                @if (hasIcon && content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" height="16" width="16" aria-hidden="true" />
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                }
                else if (hasIcon && content.IconLocation != "Prepend")
                {
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                    <inline-svg media-item="content.Icon"  height="16" width="16" aria-hidden="true" />
                }
                else
                {
                    @content.Text
                }
            </a>
        }
        else
        {
            <button type="button" class="btn__button btn__secondary @blockClasses" style="@styles.ToString()" aria-label="@accessibleName">@content.Text</button>
        }

        break;
    case "Outline":
        if (!string.IsNullOrWhiteSpace(linkUrl))
        {
            <a class="btn__button btn__outline @blockClasses" style="@styles.ToString()" href="@linkUrl" target="@(string.IsNullOrWhiteSpace(linkTarget) ? null : linkTarget)" rel="@(linkTarget == "_blank" ? "noopener noreferrer" : null)" aria-label="@accessibleName">
                @if (hasIcon && content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon"  height="16" width="16" aria-hidden="true" />
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                }
                else if (hasIcon && content.IconLocation != "Prepend")
                {
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                    <inline-svg media-item="content.Icon"  height="16" width="16" aria-hidden="true" />
                }
                else
                {
                    @content.Text
                }
            </a>
        }
        else
        {
            <button type="button" class="btn__button btn__outline @blockClasses" style="@styles.ToString()">@content.Text</button>
        }

        break;
    default:
        if (!string.IsNullOrWhiteSpace(linkUrl))
        {
            <a class="btn__button btn__primary @blockClasses" style="@styles.ToString()" href="@linkUrl" target="@(string.IsNullOrWhiteSpace(linkTarget) ? null : linkTarget)" rel="@(linkTarget == "_blank" ? "noopener noreferrer" : null)" aria-label="@accessibleName">
                @if (hasIcon && content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon"  height="16" width="16" aria-hidden="true" />
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                }
                else if (hasIcon && content.IconLocation != "Prepend")
                {
                    @if (hasText) { @content.Text } else { <span class="visually-hidden">@accessibleName</span> }
                    <inline-svg media-item="content.Icon"  height="16" width="16" aria-hidden="true" />
                }
                else
                {
                    @content.Text
                }
            </a>
        }
        else
        {
            <button type="button" class="btn__button btn__primary @blockClasses" style="@styles.ToString()">@content.Text</button>
        }

        break;
}