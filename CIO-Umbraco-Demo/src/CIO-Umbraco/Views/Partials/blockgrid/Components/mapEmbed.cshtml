@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockGridItem<ContentModels.MapEmbed>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var width = content.Width == 0 ? 600 : content.Width;
    var height = content.Height == 0 ? 450 : content.Height;

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    // Accessibility helpers
    var mapUrl = content.GoogleMapLink;
    var mapTitle = !string.IsNullOrWhiteSpace(mapUrl) ? "Map location" : "Embedded map";
    var allowFullScreenAttr = content.AllowFullScreen ? " allowfullscreen" : string.Empty;
}

@if (!string.IsNullOrWhiteSpace(blockClasses))
{
    <div class="@blockClasses">
        <figure class="map-embed__figure">
            <iframe
                src="@mapUrl"
                width="@width"
                height="@height"
                title="@mapTitle"
                aria-label="@mapTitle"
                style="border: 0;"
                @Html.Raw(allowFullScreenAttr)
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
            <figcaption class="visually-hidden">Map: @mapTitle. <a href="@mapUrl" target="_blank" rel="noopener noreferrer">Open location in Google Maps (opens in a new tab)</a></figcaption>
        </figure>
    </div>
}
else
{
    <figure class="map-embed__figure">
        <iframe
            src="@mapUrl"
            width="@width"
            height="@height"
            title="@mapTitle"
            aria-label="@mapTitle"
            style="border: 0;"
            @Html.Raw(allowFullScreenAttr)
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        <figcaption class="visually-hidden">Map: @mapTitle. <a href="@mapUrl" target="_blank" rel="noopener noreferrer">Open location in Google Maps (opens in a new tab)</a></figcaption>
    </figure>
}