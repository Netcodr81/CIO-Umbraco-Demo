@using CIO_Umbraco_Demo.Views.Partials.Forms.Models
@inherits UmbracoViewPage<BlockGridItem<ContentModels.ServiceRequestForm>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var model = new ServiceRequestFormViewModel() { FormId = content.FormId!, SuccessMessage = content.SuccessMessage!};
}

@await Html.PartialAsync("~/Views/Partials/Forms/Views/ServiceRequestForm.cshtml", model)