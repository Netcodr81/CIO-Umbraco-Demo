@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockListItem<ContentModels.IconButtonCard>>

@{
    if (Model?.Content is null) return;

    var content = Model.Content;

    var theme = Umbraco.GetCurrentTheme();

    string defaultBackgroundColor = null;
    string defaultBackgroundHoverColor = null;
    string defaultIconColor = null;
    string defaultIconHoverColor = null;
    string defaultTextColor = null;
    string defaultTextHoverColor = null;

    switch (theme)
    {
        case "blue":
            defaultBackgroundColor = "#00607f";
            defaultBackgroundHoverColor = "#bbd4dd";
            defaultIconColor = "#bbd4dd";
            defaultIconHoverColor = "#004d66";
            defaultTextColor = "#ffffff";
            defaultTextHoverColor = "#ffffff";
            break;
        case "green" :
            defaultBackgroundColor = "#BABF33";
            defaultBackgroundHoverColor = "#E3E6B3";
            defaultIconColor = "#E3E6B3";
            defaultIconHoverColor = "#949926";
            defaultTextColor = "#1b1b1b";
            defaultTextHoverColor = "#1b1b1b";
            break;
        case "red":
            defaultBackgroundColor = "#B3314E";
            defaultBackgroundHoverColor = "#E8B8C5";
            defaultIconColor = "#E8B8C5";
            defaultIconHoverColor = "#8F273E";
            defaultTextColor = "#ffffff";
            defaultTextHoverColor = "#ffffff";
            break;
    }

    var textColor = content.TextColor?.Color ?? defaultTextHoverColor!;
    var textHoverColor = content.TextHoverColor?.Color ?? defaultTextHoverColor;
    var backgroundColor = content.BackgroundColor?.Color ?? defaultBackgroundColor;
    var backgroundHoverColor = content.BackgroundHoverColor?.Color ?? defaultBackgroundHoverColor;
    var iconColor = content.IconColor?.Color ?? defaultIconColor;
    var iconHoverColor = content.IconHoverColor?.Color ?? defaultIconHoverColor;

    var cssVariables = $@"
       --icon-button-text-color: {textColor};
       --icon-button-text-hover-color: {textHoverColor};
       --icon-button-background-color: {backgroundColor};
       --icon-button-background-hover-color: {backgroundHoverColor};
       --icon-button-icon-color: {iconColor};
       --icon-button-icon-hover-color: {iconHoverColor};
    ";

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    // Link accessibility helpers
    var linkUrl = content?.Link?.Url;
    var linkTarget = string.IsNullOrWhiteSpace(content?.Link?.Target) ? "_self" : content?.Link?.Target;
    var relAttr = linkTarget == "_blank" ? "noopener noreferrer" : string.Empty;

    // If the button has no visible text, provide an accessible name from the link or icon
    var ariaLabel = string.IsNullOrWhiteSpace(content?.Text)
        ? (content?.Link?.Name ?? content?.Text ?? content?.Link?.Url ?? "Open link")
        : null;
    var ariaAttr = ariaLabel is null ? string.Empty : $"aria-label=\"{ariaLabel}\"";
    var svgAriaHidden = string.IsNullOrWhiteSpace(content?.Text) ? "false" : "true";
}

<a class="icon-button-card__container @blockClasses" href="@linkUrl" target="@linkTarget" rel="@relAttr" @Html.Raw(ariaAttr) role="listitem" style="@cssVariables">
    <div class="icon-button-card__card-body">
        <inline-svg media-item="@content?.Icon" fill="@iconColor" width="120" height="120"  aria-hidden='@svgAriaHidden'></inline-svg>
    </div>
    <div >
        <span class="icon-button-card__link">
            @content?.Text
        </span>
    </div>
</a>