@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@inherits UmbracoViewPage<BlockGridItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var borderColor = content.Value<ColorPickerValueConverter.PickedColor>("borderColor")?.Color ?? "#004d66";
    var backgroundColor = content.Value<ColorPickerValueConverter.PickedColor>("backgroundColor")?.Color ?? "#00607f";
    var textColor = content.Value<ColorPickerValueConverter.PickedColor>("textColor")?.Color ?? "#000000";
    var headingColor = content.Value<ColorPickerValueConverter.PickedColor>("headingTextColor")?.Color ?? "#000000";
    var headingFontSize = !string.IsNullOrWhiteSpace(content.Value<string>("headingFontSize")) ? content.Value<string>("headingFontSize") : "1.37rem";
    var textFontSize = !string.IsNullOrWhiteSpace(content.Value<string>("textFontSize")) ? content.Value<string>("textFontSize") : ".99rem";

    var cssVariables = $@"
        --summary-box-border-color: {borderColor};
        --summary-box-background-color: {backgroundColor};
        --summary-box-text-color: {textColor};
        --summary-box-heading-color: {headingColor};
        --summary-box-heading-font-size: {headingFontSize};
        --summary-box-text-font-size: {textFontSize};
    ";

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();
}
@{
    // Accessibility: provide a region name via heading or aria-label
    var headingText = content.Value<string>("heading");
    var hasHeading = !string.IsNullOrWhiteSpace(headingText);
    var headingId = hasHeading ? "summary-box-heading-" + Guid.NewGuid().ToString("N").Substring(0, 8) : null;
    var regionAttr = hasHeading
        ? $"role=\"region\" aria-labelledby=\"{headingId}\""
        : $"role=\"region\" aria-label=\"Summary\"";

    var textHtml = content.Value<object>("text")?.ToString() ?? string.Empty;
}

<div class="summary-box__container @blockClasses" style="@cssVariables" @Html.Raw(regionAttr)>
    @if (!string.IsNullOrWhiteSpace(headingText))
    {
        <h2 id="@headingId" class="summary-box__heading">@headingText</h2>
    }

    <div class="summary-box__text">
        @Html.Raw(textHtml)
    </div>

</div>