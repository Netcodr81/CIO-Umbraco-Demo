@using System.Text
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@using PickedColor = Umbraco.Cms.Core.PropertyEditors.ValueConverters.ColorPickerValueConverter.PickedColor
@using Umbraco.Extensions
@inherits UmbracoViewPage<BlockListItem>

@{
    if (Model is null) return;

    var content = Model.Content;

    var siteSettings = Umbraco.AssignedContentItem?.Root()?.FirstChild<SiteSettings>();
    var theme = siteSettings?.Theme?.ToLowerInvariant() ?? "blue";

    string defaultHeaderTextColor = null;
    string defaultHeaderTextHoverColor = null;

    string defaultBodyTextColor = null;
    string defaultBodyTextHoverColor = null;

    string defaultBackgroundColor = null;
    string defaultBackgroundHoverColor = null;

    string defaultIconColor = null;
    string defaultIconHoverColor = null;

    string defaultButtonTextColor = null;
    string defaultButtonTextHoverColor = null;

    string defaultButtonBackgroundColor = null;
    string defaultButtonBackgroundHoverColor = null;


    switch (theme)
    {
        case "blue":
            defaultHeaderTextColor = "#1b1b1b";
            defaultHeaderTextHoverColor = "#1b1b1b";
            defaultBodyTextColor = "#1b1b1b";
            defaultBodyTextHoverColor = "#1b1b1b";
            defaultBackgroundColor = "#ffffff";
            defaultBackgroundHoverColor = "#ffffff";
            defaultIconColor = "#ffffff";
            defaultIconHoverColor = "#ffffff";
            defaultButtonTextColor = "#ffffff";
            defaultButtonTextHoverColor = "#ffffff";
            defaultButtonBackgroundColor = "#00607f";
            defaultButtonBackgroundHoverColor = "#004d66";
            break;
        case "green":
            defaultHeaderTextColor = "#1b1b1b";
            defaultHeaderTextHoverColor = "#1b1b1b";
            defaultBodyTextColor = "#1b1b1b";
            defaultBodyTextHoverColor = "#1b1b1b";
            defaultBackgroundColor = "#ffffff";
            defaultBackgroundHoverColor = "#ffffff";
            defaultIconColor = "#ffffff";
            defaultIconHoverColor = "#ffffff";
            defaultButtonTextColor = "#1b1b1b";
            defaultButtonTextHoverColor = "#1b1b1b";
            defaultButtonBackgroundColor = "#BABF33";
            defaultButtonBackgroundHoverColor = "#949926";
            break;
        case "red":
            defaultHeaderTextColor = "#1b1b1b";
            defaultHeaderTextHoverColor = "#1b1b1b";
            defaultBodyTextColor = "#1b1b1b";
            defaultBodyTextHoverColor = "#1b1b1b";
            defaultBackgroundColor = "#ffffff";
            defaultBackgroundHoverColor = "#ffffff";
            defaultIconColor = "#ffffff";
            defaultIconHoverColor = "#ffffff";
            defaultButtonTextColor = "#ffffff";
            defaultButtonTextHoverColor = "#ffffff";
            defaultButtonBackgroundColor = "#B3314E";
            defaultButtonBackgroundHoverColor = "#8F273E";
            break;
    }


    var headerTextColor = content.Value<PickedColor>("cardHeaderTextColor")?.Color ?? defaultHeaderTextColor;
    var headerTextHoverColor = content.Value<PickedColor>("cardHeaderTextHoverColor")?.Color ?? defaultHeaderTextHoverColor;
    var bodyTextColor = content.Value<PickedColor>("cardBodyTextColor")?.Color ?? defaultBodyTextColor;
    var bodyTextHoverColor = content.Value<PickedColor>("cardBodyTextHoverColor")?.Color ?? defaultBodyTextHoverColor;
    var backgroundColor = content.Value<PickedColor>("cardBackgroundColor")?.Color ?? defaultBackgroundColor;
    var backgroundHoverColor = content.Value<PickedColor>("cardBackgroundHoverColor")?.Color ?? defaultBackgroundHoverColor;
    var iconHoverColor = content.Value<PickedColor>("cardIconHoverColor")?.Color ?? defaultIconHoverColor;
    var buttonTextColor = content.Value<PickedColor>("cardButtonTextColor")?.Color ?? defaultButtonTextColor;
    var buttonTextHoverColor = content.Value<PickedColor>("cardButtonTextHoverColor")?.Color ?? defaultButtonTextHoverColor;
    var buttonBackgroundColor = content.Value<PickedColor>("cardButtonBackgroundColor")?.Color ?? defaultButtonBackgroundColor;
    var buttonBackgroundHoverColor = content.Value<PickedColor>("cardButtonBackgroundHoverColor")?.Color ?? defaultButtonBackgroundHoverColor;

    var heightVariables = new StringBuilder();

    if (!string.IsNullOrWhiteSpace(content.Value<string>("minHeight")))
    {
        heightVariables.Append($"min-height:{content.Value<string>("minHeight")}");
    }

    if (!string.IsNullOrWhiteSpace(content.Value<string>("maxHeight")))
    {
        heightVariables.Append($"max-height:{content.Value<string>("maxHeight")}");
    }

    if (!string.IsNullOrWhiteSpace(content.Value<string>("height")))
    {
        heightVariables.Append($"height:{content.Value<string>("height")}");
    }

    var cssVariables = $@"
        --info-card-header-text-color: {headerTextColor};
        --info-card-header-text-hover-color: {headerTextHoverColor};
        --info-card-body-text-color: {bodyTextColor};
        --info-card-body-text-hover-color: {bodyTextHoverColor};
        --info-card-background-color: {backgroundColor};
        --info-card-background-hover-color: {backgroundHoverColor};
        --info-card-icon-hover-color: {iconHoverColor};
        --info-card-button-text-color: {buttonTextColor};
        --info-card-button-text-hover-color: {buttonTextHoverColor};
        --info-card-button-background-color: {buttonBackgroundColor};
        --info-card-button-background-hover-color: {buttonBackgroundHoverColor};
    ";
}

@{
    // Prepare link attributes for accessibility
    var linkObj = content.Value<Link>("link");
    var linkUrl = linkObj?.Url;
    var linkTarget = string.IsNullOrWhiteSpace(linkObj?.Target) ? "_self" : linkObj?.Target;
    var relAttr = linkTarget == "_blank" ? "noopener noreferrer" : string.Empty;

    // Read frequently used values into locals to avoid Razor parsing issues with generics in markup
    var isIconCard = content.Value<bool>("isIconCard");
    var headerText = content.Value<string>("headerText");
    var bodyText = content.Value<string>("bodyText");
    var buttonText = content.Value<string>("buttonText");
    var buttonIcon = content.Value<MediaWithCrops>("buttonIcon");
    var buttonIconLocation = content.Value<string>("buttonIconLocation");
    var iconColor = content.Value<PickedColor>("iconColor")?.Color;
    var headerIconColor = content.Value<PickedColor>("headerIconColor")?.Color;
    var image = content.Value<MediaWithCrops>("image");

    // Accessible name for buttons/links when text is missing
    var buttonAriaLabel = string.IsNullOrWhiteSpace(buttonText)
        ? (linkObj?.Name ?? headerText ?? bodyText ?? "More information")
        : null;

    var buttonAriaAttr = buttonAriaLabel is null ? string.Empty : $"aria-label=\"{buttonAriaLabel}\"";

    // Determine whether the card image/icon should be exposed to assistive tech
    var hasHeader = !string.IsNullOrWhiteSpace(headerText);
    var imageAlt = image?.Name ?? headerText ?? string.Empty;
}

<div class="info-card__container" style="@cssVariables @heightVariables.ToString()">

    @if (isIconCard)
    {
        <div class="info-card__icon-image">
            <inline-svg media-item="@image" fill="@headerIconColor" width="64" height="64"></inline-svg>
        </div>
    }
    else
    {
        <div class="info-card__image">
            <img src="@image?.GetCropUrl()" name="@image?.Name"/>
        </div>
    }

    @if (isIconCard)
    {
        <div class="info-card__icon-card-header">
            <h3>@headerText</h3>
        </div>
    }
    else
    {
        <div class="info-card__header">
            <h3>@headerText</h3>
        </div>
    }


    @if (!string.IsNullOrWhiteSpace(bodyText))
    {
        <div class="info-card__body">
            @Html.Raw(bodyText)
        </div>
    }

    <div class="info-card__footer">
        @if (linkObj is not null && !string.IsNullOrWhiteSpace(linkUrl))
        {
            <a class="info-card__button" href="@linkUrl" target="@linkTarget" rel="@relAttr" @Html.Raw(buttonAriaAttr)>
                @if (buttonIcon is not null)
                {
                    if (content.Value<string>("buttonIconLocation") == "Prepend")
                    {
                        <inline-svg media-item="@buttonIcon" width="16" height="16" fill="@(iconColor ?? defaultIconColor)" aria-hidden='@(string.IsNullOrWhiteSpace(buttonText) ? "false" : "true")'></inline-svg>
                        @buttonText
                    }
                    else
                    {
                        @buttonText
                        <inline-svg media-item="@buttonIcon" width="16" height="16" fill="@(iconColor ?? defaultIconColor)" aria-hidden='@(string.IsNullOrWhiteSpace(buttonText) ? "false" : "true")'></inline-svg>
                    }
                }
                else
                {
                    @buttonText
                }
            </a>
        }
        else
        {
            // If no link is provided, render a non-interactive element styled like a button and communicate disabled state
            <span class="info-card__button info-card__button--disabled" aria-disabled="true">@buttonText</span>
        }

    </div>
</div>