@using System.Text
@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockListItem<ContentModels.InfoCard>>

@{
    if (Model?.Content is null) return;

    var content = Model.Content;

    var theme = Umbraco.GetCurrentTheme();
   
    string defaultHeaderTextColor = null;
    string defaultHeaderTextHoverColor = null;

    string defaultBodyTextColor = null;
    string defaultBodyTextHoverColor = null;

    string defaultBackgroundColor = null;
    string defaultBackgroundHoverColor = null;

    string defaultIconColor = null;
    string defaultIconHoverColor = null;

    string defaultButtonTextColor = null;
    string defaultButtonTextHoverColor = null;

    string defaultButtonBackgroundColor = null;
    string defaultButtonBackgroundHoverColor = null;
    
    

    switch (theme)
    {
        case "blue":
            defaultHeaderTextColor = "#1b1b1b";
            defaultHeaderTextHoverColor = "#1b1b1b";
            defaultBodyTextColor = "#1b1b1b";
            defaultBodyTextHoverColor = "#1b1b1b";
            defaultBackgroundColor = "#ffffff";
            defaultBackgroundHoverColor = "#ffffff";
            defaultIconColor = "#ffffff";
            defaultIconHoverColor = "#ffffff";
            defaultButtonTextColor = "#ffffff";
            defaultButtonTextHoverColor = "#ffffff";
            defaultButtonBackgroundColor = "#00607f";
            defaultButtonBackgroundHoverColor = "#004d66";
            break;
        case "green" :
            defaultHeaderTextColor = "#1b1b1b";
            defaultHeaderTextHoverColor = "#1b1b1b";
            defaultBodyTextColor = "#1b1b1b";
            defaultBodyTextHoverColor = "#1b1b1b";
            defaultBackgroundColor = "#ffffff";
            defaultBackgroundHoverColor = "#ffffff";
            defaultIconColor = "#ffffff";
            defaultIconHoverColor = "#ffffff";
            defaultButtonTextColor = "#1b1b1b";
            defaultButtonTextHoverColor = "#1b1b1b";
            defaultButtonBackgroundColor = "#BABF33";
            defaultButtonBackgroundHoverColor = "#949926";
            break;
        case "red":
            defaultHeaderTextColor = "#1b1b1b";
            defaultHeaderTextHoverColor = "#1b1b1b";
            defaultBodyTextColor = "#1b1b1b";
            defaultBodyTextHoverColor = "#1b1b1b";
            defaultBackgroundColor = "#ffffff";
            defaultBackgroundHoverColor = "#ffffff";
            defaultIconColor = "#ffffff";
            defaultIconHoverColor = "#ffffff";
            defaultButtonTextColor = "#ffffff";
            defaultButtonTextHoverColor = "#ffffff";
            defaultButtonBackgroundColor = "#B3314E";
            defaultButtonBackgroundHoverColor = "#8F273E";
            break;
    }
    

    var headerTextColor = content.CardHeaderTextColor?.Color ?? defaultHeaderTextColor;
    var headerTextHoverColor = content.CardHeaderTextHoverColor?.Color ?? defaultHeaderTextHoverColor;
    var bodyTextColor = content.CardBodyTextColor?.Color ?? defaultBodyTextColor;
    var bodyTextHoverColor = content.CardBodyTextHoverColor?.Color ?? defaultBodyTextHoverColor;
    var backgroundColor = content.CardBackgroundColor?.Color ?? defaultBackgroundColor;
    var backgroundHoverColor = content.CardBackgroundHoverColor?.Color ?? defaultBackgroundHoverColor;
    var iconHoverColor = content.CardIconHoverColor?.Color ?? defaultIconHoverColor;
    var buttonTextColor = content.CardButtonTextColor?.Color ?? defaultButtonTextColor;
    var buttonTextHoverColor = content.CardButtonTextHoverColor?.Color ?? defaultButtonTextHoverColor;
    var buttonBackgroundColor = content.CardButtonBackgroundColor?.Color ?? defaultButtonBackgroundColor;
    var buttonBackgroundHoverColor = content.CardButtonBackgroundHoverColor?.Color ?? defaultButtonBackgroundHoverColor;

    var heightVariables = new StringBuilder();

    if(!string.IsNullOrWhiteSpace(content.MinHeight))
    {
        heightVariables.Append($"min-height:{content.MinHeight}");
    }

    if (!string.IsNullOrWhiteSpace(content.MaxHeight))
    {
        heightVariables.Append($"max-height:{content.MaxHeight}");
    }

    if (!string.IsNullOrWhiteSpace(content.Height))
    {
        heightVariables.Append($"height:{content.Height}");
    }

    var cssVariables = $@"
        --info-card-header-text-color: {headerTextColor};
        --info-card-header-text-hover-color: {headerTextHoverColor};
        --info-card-body-text-color: {bodyTextColor};
        --info-card-body-text-hover-color: {bodyTextHoverColor};
        --info-card-background-color: {backgroundColor};
        --info-card-background-hover-color: {backgroundHoverColor};
        --info-card-icon-hover-color: {iconHoverColor};
        --info-card-button-text-color: {buttonTextColor};
        --info-card-button-text-hover-color: {buttonTextHoverColor};
        --info-card-button-background-color: {buttonBackgroundColor};
        --info-card-button-background-hover-color: {buttonBackgroundHoverColor};
    ";
}

@{
    // Prepare link attributes for accessibility
    var linkUrl = content?.Link?.Url;
    var linkTarget = string.IsNullOrWhiteSpace(content?.Link?.Target) ? "_self" : content?.Link?.Target;
    var relAttr = linkTarget == "_blank" ? "noopener noreferrer" : string.Empty;

    // Accessible name for buttons/links when text is missing
    var buttonAriaLabel = string.IsNullOrWhiteSpace(content?.ButtonText)
        ? (content?.Link?.Name ?? content?.HeaderText ?? content?.BodyText ?? "More information")
        : null;

    var buttonAriaAttr = buttonAriaLabel is null ? string.Empty : $"aria-label=\"{buttonAriaLabel}\"";

    // Determine whether the card image/icon should be exposed to assistive tech
    var hasHeader = !string.IsNullOrWhiteSpace(content?.HeaderText);
    var imageAlt = content?.Image?.Name ?? content?.HeaderText ?? string.Empty;
}

<div class="info-card__container" style="@cssVariables @heightVariables.ToString()">
    
    @if (content.IsIconCard)
    {
        <div class="info-card__icon-image">
            <inline-svg media-item="content.Image" fill="@content?.HeaderIconColor?.Color" width="64" height="64"></inline-svg>
        </div>
    }
    else
    {
        <div class="info-card__image">
            <img src="@content?.Image?.GetCropUrl()" name="@content?.Image?.Name"/>
        </div>
    }
    
    @if (content.IsIconCard)
    {
        <div class="info-card__icon-card-header">
            <h3>@content?.HeaderText</h3>
        </div>
    }
    else
    {
        <div class="info-card__header">
            <h3>@content?.HeaderText</h3>
        </div>
    }
   
    
    @if (!string.IsNullOrWhiteSpace(content?.BodyText))
    {
        <div class="info-card__body">
            @content?.BodyText
        </div>
    }

    <div class="info-card__footer">
        @if (content?.Link is not null && !string.IsNullOrWhiteSpace(linkUrl))
        {
            <a class="info-card__button" href="@linkUrl" target="@linkTarget" rel="@relAttr" @Html.Raw(buttonAriaAttr)>
                @if (content.ButtonIcon is not null)
                {
                    if (content.ButtonIconLocation == "Prepend")
                    {
                        <inline-svg media-item="@content.ButtonIcon" width="16" height="16" fill="@(content?.IconColor?.Color ?? defaultIconColor)" aria-hidden='@(string.IsNullOrWhiteSpace(content?.ButtonText) ? "false" : "true")'></inline-svg>
                        @content?.ButtonText
                    }
                    else
                    {
                        @content.ButtonText
                        <inline-svg media-item="@content.ButtonIcon" width="16" height="16" fill="@(content?.IconColor?.Color ?? defaultIconColor)" aria-hidden='@(string.IsNullOrWhiteSpace(content?.ButtonText) ? "false" : "true")'></inline-svg>
                    }
                }
                else
                {
                    @content.ButtonText
                }
            </a>
        }
        else
        {
            // If no link is provided, render a non-interactive element styled like a button and communicate disabled state
            <span class="info-card__button info-card__button--disabled" aria-disabled="true">@content?.ButtonText</span>
        }

    </div>
</div>