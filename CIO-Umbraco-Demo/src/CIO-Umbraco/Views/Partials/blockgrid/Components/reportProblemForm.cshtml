@using CIO_Umbraco_Demo.Views.Partials.Forms.Models
@inherits UmbracoViewPage<BlockGridItem<ContentModels.ReportProblemForm>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var model = new ReportProblemFormViewModel() { FormId = content.FormId!, SuccessMessage = content.SuccessMessage! };
}

@await Html.PartialAsync("~/Views/Partials/Forms/Views/ReportProblemForm.cshtml", model)