
@using Umbraco.Extensions
@inherits UmbracoViewPage<BlockGridItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var width = !string.IsNullOrWhiteSpace(content.Value<string>("width")) ? content.Value<string>("width") : "100%";
    var height = !string.IsNullOrWhiteSpace(content.Value<string>("height")) ? content.Value<string>("height") : "100%";
    var tabletWidth = !string.IsNullOrWhiteSpace(content.Value<string>("tabletWidth")) ? content.Value<string>("tabletWidth") : "100%";
    var tabletHeight = !string.IsNullOrWhiteSpace(content.Value<string>("tabletHeight")) ? content.Value<string>("tabletHeight") : "100%";
    var mobileWidth = !string.IsNullOrWhiteSpace(content.Value<string>("mobileWidth")) ? content.Value<string>("mobileWidth") : "100%";
    var mobileHeight = !string.IsNullOrWhiteSpace(content.Value<string>("mobileHeight")) ? content.Value<string>("mobileHeight") : "100%";

    var fontSize = !string.IsNullOrWhiteSpace(content.Value<string>("fontSize")) ? content.Value<string>("fontSize") : ".81rem";
    var tabletFontSize = !string.IsNullOrWhiteSpace(content.Value<string>("tabletFontSize")) ? content.Value<string>("tabletFontSize") : ".80rem";
    var mobileFontSize = !string.IsNullOrWhiteSpace(content.Value<string>("mobileFontSize")) ? content.Value<string>("mobileFontSize") : ".75rem";

    var styles = $@"
        --figure__width: {width};
        --figure__height: {height};
        --figure__tablet-width: {tabletWidth};
        --figure__tablet-height: {tabletHeight};
        --figure__mobile-width: {mobileWidth};
        --figure__mobile-height: {mobileHeight};
        --figure__font-size: {fontSize};
        --figure__tablet-font-size: {tabletFontSize};
        --figure__mobile-font-size: {mobileFontSize};
    ";

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    // Determine accessible text
    var caption = content.Value<string>("caption");
    var image = content.Value<IPublishedContent>("image");
    var imageName = image?.Name;
    var hasCaption = !string.IsNullOrWhiteSpace(caption);
    var imgAlt = string.Empty;
    if (hasCaption)
    {
        // If figcaption exists, image should be decorative to avoid duplicate announcement
        imgAlt = string.Empty;
    }
    else if (!string.IsNullOrWhiteSpace(imageName))
    {
        imgAlt = imageName;
    }
    else
    {
        imgAlt = "Figure image";
    }

    var captionId = "figure-caption-" + Guid.NewGuid().ToString("N").Substring(0,8);
}

<figure class="figure__container @blockClasses" style="@styles" @(hasCaption ? $"aria-labelledby=\"{captionId}\"" : $"aria-label=\"{imgAlt}\"")>
    @if (image != null)
    {
        var imageUrl = image.GetCropUrl();
        if (hasCaption)
        {
            <img src="@imageUrl" alt="" aria-hidden="true" loading="lazy" decoding="async"/>
        }
        else
        {
            <img src="@imageUrl" alt="@imgAlt" loading="lazy" decoding="async"/>
        }
    }

    @if (hasCaption)
    {
        <figcaption id="@captionId">@Html.Raw(caption)</figcaption>
    }
</figure>
