@inherits UmbracoViewPage<BlockListItem<ContentModels.NewsroomItem>>

@{
    if (Model?.Content is null) return;

    var content = Model.Content;

    var iconHoverColor = content?.IconHoverColor?.Color ?? "#004d66";
    var descriptionColor = content?.DescriptionColor?.Color ?? "#000";
    var linkColor = content?.LinkColor?.Color ?? "#00607f";
    var linkHoverColor = content?.LinkHoverColor?.Color ?? "#004d66";

    var cssVariables = $@"
        --newsroom-icon-hover-color: {iconHoverColor};
        --newsroom-description-color: {descriptionColor};
        --newsroom-link-color: {linkColor};
        --newsroom-link-hover-color: {linkHoverColor};
    ";
}

@{
    var linkUrl = content?.Link?.Url;
    var linkTarget = string.IsNullOrWhiteSpace(content?.Link?.Target) ? "_self" : content.Link.Target;
    var relAttr = linkTarget == "_blank" ? " rel=\"noopener noreferrer\"" : string.Empty;
    var linkText = !string.IsNullOrWhiteSpace(content?.Link?.Name) ? content.Link.Name : linkUrl;
    var ariaLabel = string.IsNullOrWhiteSpace(content?.Link?.Name) ? $"News item: {linkText}" : string.Empty;
    var ariaAttr = string.IsNullOrEmpty(ariaLabel) ? string.Empty : $" aria-label=\"{ariaLabel}\"";
    var svgAriaHidden = !string.IsNullOrWhiteSpace(content?.Link?.Name) ? "true" : "false";
}

<li class="d-flex newsroom__list-item flex-column w-100" style="@cssVariables">
    @if (!string.IsNullOrWhiteSpace(linkUrl))
    {
        <a href="@linkUrl" target="@linkTarget"@Html.Raw(relAttr + ariaAttr)>
            @if (content?.Icon is not null)
            {
                @if (content.IconLocation == "Prepend")
                {
                    <h3>
                        <inline-svg media-item="@content?.Icon" height="18" width="18" fill="currentColor" aria-hidden='@svgAriaHidden'></inline-svg>
                        @linkText
                    </h3>
                }
                else
                {
                    <h3>
                        @linkText
                        <inline-svg media-item="@content?.Icon" height="18" width="18" fill="currentColor" aria-hidden='@svgAriaHidden'></inline-svg>
                    </h3>
                }
            }
            else
            {
                <h3>@linkText</h3>
            }
        </a>
    }
    else
    {
        @if (content?.Icon is not null)
        {
            if (content.IconLocation == "Prepend")
            {
                <h3>
                    <inline-svg media-item="@content?.Icon" height="18" width="18" fill="currentColor" aria-hidden="true"></inline-svg>
                    @content?.Link?.Name
                </h3>
            }
            else
            {
                <h3>
                    @content?.Link?.Name
                    <inline-svg media-item="@content?.Icon" height="18" width="18" fill="currentColor" aria-hidden="true"></inline-svg>
                </h3>
            }
        }
        else
        {
            <h3>@content?.Link?.Name</h3>
        }
    }

    <p class="newsroom__description">
        @content?.Description
    </p>
</li>
