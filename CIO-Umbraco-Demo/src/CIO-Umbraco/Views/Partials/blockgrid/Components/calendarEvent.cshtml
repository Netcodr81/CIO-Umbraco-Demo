@inherits UmbracoViewPage<BlockListItem>

@using System.Text.Encodings.Web
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@using Umbraco.Extensions
@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var picked = content.Value<ColorPickerValueConverter.PickedColor>("eventColor");
    var eventColor = picked?.Color ?? "#00607f";

    // Format dates for display
    var start = content.Value<System.DateTimeOffset?>("start");
    var end = content.Value<System.DateTimeOffset?>("end");
    var startDate = start?.ToString("MMM dd, yyyy");
    var startTime = start?.ToString("h:mm tt");
    var endTime = end?.ToString("h:mm tt");

    var titleId = "evt-title-" + Guid.NewGuid().ToString("N").Substring(0, 8);
    var title = content.Value<string>("title") ?? string.Empty;
    var eventLocation = content.Value<string>("eventLocation");
    var eventDetails = content.Value<string>("eventDetails");
}

<article class="calendar-event-card" style="--event-color: @eventColor;" role="article" aria-labelledby="@titleId">
    <div class="calendar-event-card__color-bar" aria-hidden="true"></div>

    <div class="calendar-event-card__content">
        <!-- Date & Time Section -->
        <div class="calendar-event-card__datetime">
            <div class="calendar-event-card__date">
                @if (start.HasValue)
                {
                    <time class="calendar-event-card__month" datetime="@start.Value.ToString("yyyy-MM-dd")">@start.Value.ToString("MMM")</time>
                    <time class="calendar-event-card__day" datetime="@start.Value.ToString("yyyy-MM-dd")">@start.Value.ToString("dd")</time>
                }
            </div>
            <div class="calendar-event-card__time-range">
                @if (start.HasValue)
                {
                    <div class="calendar-event-card__time">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                            <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm0 14.5a6.5 6.5 0 1 1 0-13 6.5 6.5 0 0 1 0 13z"/>
                            <path d="M7.5 3v5l4.5 2.5.5-.9L8.5 7.5V3h-1z"/>
                        </svg>
                        <span>@startTime @(endTime != null ? $"- {endTime}" : "")</span>
                    </div>
                }
            </div>
        </div>

        <!-- Title -->
        <h3 id="@titleId" class="calendar-event-card__title">@title</h3>

        <!-- Details -->
        <div class="calendar-event-card__details">
            @if (!string.IsNullOrWhiteSpace(eventLocation))
            {
                <div class="calendar-event-card__detail-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" focusable="false">
                        <path d="M8 0a5 5 0 0 0-5 5c0 3.25 5 11 5 11s5-7.75 5-11a5 5 0 0 0-5-5zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
                    </svg>
                    <span>@Html.Encode(eventLocation)</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(eventDetails))
            {
                <div class="calendar-event-card__detail-item calendar-event-card__detail-item--description">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" focusable="false">
                        <path d="M2 2h12v12H2V2zm1 1v10h10V3H3zm1 2h8v1H4V5zm0 2h8v1H4V7zm0 2h5v1H4V9z"/>
                    </svg>
                    <span>@Html.Raw(HtmlEncoder.Default.Encode(eventDetails).Replace("\n", "<br/>"))</span>
                </div>
            }
        </div>
    </div>

</article>