@inherits UmbracoViewPage<BlockListItem<ContentModels.CalendarEvent>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;
    var eventColor = content?.EventColor?.Color ?? "#00607f";

    // Format dates for display
    var startDate = content.Start?.ToString("MMM dd, yyyy");
    var startTime = content.Start?.ToString("h:mm tt");
    var endTime = content.End?.ToString("h:mm tt");
}

<div class="calendar-event-card" style="--event-color: @eventColor;">
    <div class="calendar-event-card__color-bar"></div>

    <div class="calendar-event-card__content">
        <!-- Date & Time Section -->
        <div class="calendar-event-card__datetime">
            <div class="calendar-event-card__date">
                @if (content.Start.HasValue)
                {
                    <span class="calendar-event-card__month">@content.Start.Value.ToString("MMM")</span>
                    <span class="calendar-event-card__day">@content.Start.Value.ToString("dd")</span>
                }
            </div>
            <div class="calendar-event-card__time-range">
                @if (content.Start.HasValue)
                {
                    <div class="calendar-event-card__time">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                            <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm0 14.5a6.5 6.5 0 1 1 0-13 6.5 6.5 0 0 1 0 13z"/>
                            <path d="M7.5 3v5l4.5 2.5.5-.9L8.5 7.5V3h-1z"/>
                        </svg>
                        <span>@startTime @(endTime != null ? $"- {endTime}" : "")</span>
                    </div>
                }
            </div>
        </div>

        <!-- Title -->
        <h3 class="calendar-event-card__title">@content.Title</h3>

        <!-- Details -->
        <div class="calendar-event-card__details">
            @if (!string.IsNullOrWhiteSpace(content?.EventLocation))
            {
                <div class="calendar-event-card__detail-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M8 0a5 5 0 0 0-5 5c0 3.25 5 11 5 11s5-7.75 5-11a5 5 0 0 0-5-5zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
                    </svg>
                    <span>@content.EventLocation</span>
                </div>
            }

            <!-- Event Color Display -->
            <div class="calendar-event-card__detail-item">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm5 0a1 1 0 1 0-2 0v12a1 1 0 1 0 2 0V2zm3 0a1 1 0 1 0-2 0v12a1 1 0 1 0 2 0V2zm3 0a1 1 0 1 0-2 0v12a1 1 0 1 0 2 0V2z"/>
                </svg>
                <span class="calendar-event-card__color-display">
                    <span class="calendar-event-card__color-badge" style="background-color: @eventColor;"></span>
                    <span class="calendar-event-card__color-hex">@eventColor</span>
                </span>
            </div>

            @if (!string.IsNullOrWhiteSpace(content?.EventDetails))
            {
                <div class="calendar-event-card__detail-item calendar-event-card__detail-item--description">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M2 2h12v12H2V2zm1 1v10h10V3H3zm1 2h8v1H4V5zm0 2h8v1H4V7zm0 2h5v1H4V9z"/>
                    </svg>
                    <span>@Html.Raw(content.EventDetails)</span>
                </div>
            }
        </div>
    </div>
</div>
