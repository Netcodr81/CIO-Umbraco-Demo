@inherits UmbracoViewPage<BlockGridItem<HomepageHero>>
@using Umbraco.Extensions;

@{
    if (Model?.Content is null) return;

    var content = Model.Content;
    var backgroundImageUrl = content.BackgroundImage?.GetCropUrl();

    var ctaLink = content.CtaLink;
    var ctaUrl = ctaLink?.Url;
    var ctaTarget = string.IsNullOrWhiteSpace(ctaLink?.Target) ? "_self" : ctaLink.Target;

    var buttonBackgroundColor = content?.ButtonBackgroundColor?.Color ?? "#FFC44D";
    var buttonBackgroundHoverColor = content?.ButtonBackgroundHoverColor?.Color ?? "e3bf77";
    var buttonTextColor = content?.ButtonTextColor?.Color ?? "#000000";
    var buttonTextHoverColor = content?.ButtonTextHoverColor?.Color ?? "#000000";
    var headingTextColor = content?.SubheadingColor?.Color ?? "#ffffff";
    var subheadingColor = content?.SubheadingColor?.Color ?? "#ffffff";
    var svgBackgroundColor = content?.SvgBackgroundColor?.Color ?? "#4d90a5";
    var svgMidgroundColor = content?.SvgMidgroundColor?.Color ?? "#ffc44d";
    var svgForegroundColor = content?.SvgForegroundColor?.Color ?? "#f3f7fc";
    var backgroundColor = content?.BackgroundColor?.Color ?? "#00607F";

    var cssVariables = $@"
        --homepage-hero-background-image: url({backgroundImageUrl});
        --homepage-hero-background-color: {backgroundColor};
        --homepage-hero-btn-color: {buttonBackgroundColor};
        --homepage-hero-btn-hover-color: {buttonBackgroundHoverColor};
        --homepage-hero-btn-text-color: {buttonTextColor};
        --homepage-hero-btn-text-hover-color: {buttonTextHoverColor};
        --homepage-hero-heading-text-color: {headingTextColor};
        --homepage-hero-subheading-text-color: {subheadingColor};
        --homepage-hero-svg-background-color: {svgBackgroundColor};
        --homepage-hero-svg-midground-color: {svgMidgroundColor};
        --homepage-hero-svg-foreground-color: {svgForegroundColor};
    ";
}


<div class="homepage-hero__wrapper" style="background-image: url(@backgroundImageUrl);background-color:@backgroundColor; @cssVariables">
    <div class="homepage-hero__overlay"></div>
    <div class="homepage-hero__cta-callout container">
        <h1 class="homepage-hero__heading">@content?.Header</h1>
        @if (!string.IsNullOrWhiteSpace(content?.Subheading))
        {
            <p class="homepage-hero__subheader">@content?.Subheading</p>
        }
        @if (content?.CtaLink is not null)
        {
            <div class="homepage-hero__btn-container">
                <a href="@ctaUrl" target="@ctaTarget" class="homepage-hero__btn" role='button'>
                    @if (content?.ButtonIcon is not null)
                    {
                        if (content.ButtonIconLocation == "Prepend")
                        {
                            <inline-svg media-item="content.ButtonIcon"></inline-svg>
                            @content.ButtonText
                        }
                        else
                        {
                            @content.ButtonText
                            <inline-svg media-item="content.ButtonIcon"></inline-svg>
                        }
                    }
                    else
                    {
                        @content?.ButtonText
                    }

                </a>
            </div>
        }
      
    </div>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1728 103" preserveAspectRatio="none">
        <path class="homepage-hero__svg-back" d="M1728,103.5H0v-16c214.8-7.6,389.7-21.8,511.9-33.7,203.4-19.7,272.2-34.2,428.8-35,122.8-.6,172.5,7.8,379.1,19.9,176.1,10.3,318.3,14.6,408,16.7v48h.2Z"></path>
        <path class="homepage-hero__svg-mid" d="M1728,103.5v-8.5c-127.2-15.2-316.6-32.5-552-34.1-99.6-.7-106.1,2.1-184,0C707.5,53,605.9,10.3,408.1,1.1,312.2-3.3,172.5-.8,0,35.3v68.2h1728Z"></path>
        <path class="homepage-hero__svg-fore" d="M1728,79.5v24H0v-32c142-17,257.6-18,336-16,201.7,5.2,280.5,34,480,32,123.8-1.3,162.3-13.4,288-24,144.9-12.2,356.2-18.3,624,16Z"></path>
    </svg>
</div>