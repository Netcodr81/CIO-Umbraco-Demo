@using System.Text
@inherits UmbracoViewPage<BlockGridItem<ContentModels.ReturnToAnchorButton>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var hasIcon = content.Icon is not null;
    var targetAnchor = content.TargetAnchorId ?? "top";
    var anchorHref = $"#{targetAnchor}";

    var styles = new StringBuilder();

    if (!string.IsNullOrWhiteSpace(content.MinWidth))
    {
        styles.Append($" min-width:{content.MinWidth}");
    }

    if (!string.IsNullOrWhiteSpace(content.MaxWidth))
    {
        styles.Append($" max-width:{content.MaxWidth}");
    }

    if (!string.IsNullOrWhiteSpace(content.Width))
    {
        styles.Append($" width:{content.Width}");
    }

    var dividerColor = content?.DividerColor?.Color == null ? "border-top:1px solid #64748b;padding-top:1.25rem;" : $"border-top:{content?.DividerColor?.Color};padding-top:1.25rem;";

}


<div class="return-to-anchor-btn__container" style="@(content.ShowDivider ? dividerColor : string.Empty)">
@switch (content.ButtonStyle)
{
    case "Primary":
        if (hasIcon)
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" fill="#fff" height="16" width="16" />
                    @content.ButtonText
                }
                else
                {
                    @content.ButtonText
                    <inline-svg media-item="content.Icon" fill="#fff" height="16" width="16" />
                }
            </a>
        }
        else
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()">
                @content.ButtonText
            </a>
        }

        break;
    case "Secondary":
        if (hasIcon)
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__secondary return-to-anchor-btn__link" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" fill="#1b1b1b" height="16" width="16" />
                    @content.ButtonText
                }
                else
                {
                    @content.ButtonText
                    <inline-svg media-item="content.Icon" fill="#1b1b1b" height="16" width="16" />
                }
            </a>
        }
        else
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__secondary return-to-anchor-btn__link" style="@styles.ToString()">@content.ButtonText</a>
        }

        break;
    case "Outline":
        if (hasIcon)
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__outline return-to-anchor-btn__link" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" fill="#004d66" height="16" width="16" />
                    @content.ButtonText
                }
                else
                {
                    @content.ButtonText
                    <inline-svg media-item="content.Icon" fill="#004d66" height="16" width="16" />
                }
            </a>
        }
        else
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__outline return-to-anchor-btn__link" style="@styles.ToString()">@content.ButtonText</a>
        }

        break;
    default:
        if (hasIcon)
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()">
                @if (content.IconLocation == "Prepend")
                {
                    <inline-svg media-item="content.Icon" fill="#fff" height="16" width="16" />
                    @content.ButtonText
                }
                else
                {
                    @content.ButtonText
                    <inline-svg media-item="content.Icon" fill="#fff" height="16" width="16" />
                }
            </a>
        }
        else
        {
            <a href="@anchorHref" class="return-to-anchor-btn__button return-to-anchor-btn__primary return-to-anchor-btn__link" style="@styles.ToString()">@content.ButtonText</a>
        }

        break;
}
</div>

<script>
    (function() {
        document.querySelectorAll('.return-to-anchor-btn__link').forEach(function(link) {
            link.addEventListener('click', function(e) {
                e.preventDefault();

                var targetId = this.getAttribute('href').substring(1);
                var targetElement = document.getElementById(targetId);

                if (targetElement) {
                    var startPosition = window.pageYOffset;
                    var targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset;
                    var distance = targetPosition - startPosition;
                    var duration = 1200; // 1.2 seconds - adjust this for speed (higher = slower)
                    var startTime = null;

                    function easeInOutCubic(t) {
                        return t < 0.5 ? 4 * t * t * t : (t - 1) * (2 * t - 2) * (2 * t - 2) + 1;
                    }

                    function animation(currentTime) {
                        if (startTime === null) startTime = currentTime;
                        var timeElapsed = currentTime - startTime;
                        var progress = Math.min(timeElapsed / duration, 1);
                        var ease = easeInOutCubic(progress);

                        window.scrollTo(0, startPosition + (distance * ease));

                        if (timeElapsed < duration) {
                            requestAnimationFrame(animation);
                        } else {
                            // Update URL hash without jumping
                            history.pushState(null, null, '#' + targetId);
                            // Set focus for accessibility
                            targetElement.focus();
                        }
                    }

                    requestAnimationFrame(animation);
                }
            });
        });
    })();
</script>