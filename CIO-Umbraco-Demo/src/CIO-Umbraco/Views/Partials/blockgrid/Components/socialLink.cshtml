@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@inherits UmbracoViewPage<BlockListItem>

@{
    if (Model.Content == null)
        return;


    var content = Model.Content;
    var settings = Umbraco.AssignedContentItem?.Root()?.FirstChild<SiteSettings>();

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    var linkUrl = content?.Value<Link>("link")?.Url;
    var linkTarget = content?.Value<Link>("link")?.Target ?? "_blank";
    var linkName = content?.Value<Link>("link")?.Name ?? content?.Value<Link>("link")?.Name ?? linkUrl ?? "Social link";
}

@* Only render when URL is provided *@
@if (!string.IsNullOrWhiteSpace(linkUrl))
{
    <a class="social-link @blockClasses" href="@linkUrl" target="@linkTarget" rel="noopener noreferrer" aria-label="@linkName" title="@linkName">
        <inline-svg media-item="@(content?.Value<MediaWithCrops>("icon"))" fill="@(content?.Value<string>("fillColor"))" background-color="@(content?.Value<string>("backgroundColor"))" height="35" width="35" aria-hidden="true"></inline-svg>
        <span class="visually-hidden">@linkName</span>
    </a>
}
