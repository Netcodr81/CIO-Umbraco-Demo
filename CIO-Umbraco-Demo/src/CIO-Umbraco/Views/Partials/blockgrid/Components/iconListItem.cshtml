@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockListItem<ContentModels.IconListItem>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var iconSize = (content?.IconSize ?? 0) == 0 ? 24 : content.IconSize;

    var theme = Umbraco.GetCurrentTheme();

    string defaultIconColor = null;

    switch (theme)
    {
        case "blue":
            defaultIconColor = "#00607f";
            break;
        case "green" :
            defaultIconColor = "#BABF33";
            break;
        case "red":
            defaultIconColor = "#B3314E";
            break;
    }

    // Accessibility: hide icon from assistive tech when there is accompanying text.
    // If there is no text, expose the SVG as an image with a fallback accessible name.
    var hasText = content?.Text is not null;
    var svgAriaHidden = hasText ? "true" : "false";
    var svgAriaLabel = hasText ? null : (content?.Icon?.Name ?? "Icon");
}

<li class="icon-list__list-item-content" style="display:flex;gap:10px;">
    <inline-svg media-item="@content?.Icon" fill="@(content?.IconColor?.Color ?? defaultIconColor)" width="@iconSize" height="24" aria-hidden="@svgAriaHidden" role="@(hasText ? "presentation" : "img")" aria-label="@svgAriaLabel" ></inline-svg>
    <div class="icon-list__list-item-container">
        <span>@content?.Text</span>
    </div>
</li>
