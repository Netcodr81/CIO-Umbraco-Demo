@using Umbraco.Extensions
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Strings
@inherits UmbracoViewPage<BlockListItem>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var iconSizeRaw = content.Value<int?>("iconSize");
    var iconSize = (iconSizeRaw.HasValue && iconSizeRaw.Value > 0) ? iconSizeRaw.Value : 24;

    var siteSettings = Umbraco.AssignedContentItem?.Root()?.FirstChild<SiteSettings>();
    var theme = siteSettings?.Value<string>("theme")?.ToLowerInvariant() ?? "blue";

    string defaultIconColor = null;

    switch (theme)
    {
        case "blue":
            defaultIconColor = "#00607f";
            break;
        case "green" :
            defaultIconColor = "#BABF33";
            break;
        case "red":
            defaultIconColor = "#B3314E";
            break;
    }

    var icon = content.Value<IPublishedContent>("icon");
    var iconColorPicked = content.Value<ColorPickerValueConverter.PickedColor>("iconColor");
    var iconColor = iconColorPicked?.Color ?? defaultIconColor;

    // Accessibility: hide icon from assistive tech when there is accompanying text.
    // If there is no text, expose the SVG as an image with a fallback accessible name.
    var text = content.Value<IHtmlEncodedString>("text");
    var hasText = !string.IsNullOrWhiteSpace(text.ToHtmlString());
    var svgAriaHidden = hasText ? "true" : "false";
    var svgAriaLabel = hasText ? null : (icon?.Name ?? "Icon");
}

<li class="icon-list__list-item-content" style="display:flex;gap:10px;">
    <inline-svg media-item="@(icon)" fill="@iconColor" width="@iconSize" height="24" aria-hidden="@svgAriaHidden" role="@(hasText ? "presentation" : "img")" aria-label="@svgAriaLabel" ></inline-svg>
    <div class="icon-list__list-item-container">
        <span>@text</span>
    </div>
</li>
