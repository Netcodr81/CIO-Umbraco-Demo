@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockGridItem<ContentModels.InPageNavigation>>

@{
    if (Model?.Content is null) return;
    var content = Model.Content;
    
    // Generate unique ID for this navigation instance
    var navId = "in-page-nav-" + Guid.NewGuid().ToString("N").Substring(0, 8);

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();
}

<nav class="in-page-nav @blockClasses" id="@navId" aria-label="In-page navigation">
    <div class="in-page-nav__container">
        @if (!string.IsNullOrEmpty(content.Heading))
        {
            <h4 class="in-page-nav__heading">@content.Heading</h4>
        }
        <ul class="in-page-nav__list" role="list">
            @* Navigation items will be populated by JavaScript *@
        </ul>
    </div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const nav = document.getElementById('@navId');
        if (!nav) {
            console.warn('In-page nav element not found');
            return;
        }

        const navList = nav.querySelector('.in-page-nav__list');
        if (!navList) {
            console.warn('In-page nav list not found');
            return;
        }

        // Find all H2 and H3 headings in the content columns
        // Look for headings within layout-items or feature-items divs
        const layoutItems = document.querySelectorAll('.layout-items, .feature-items');
  

        let allHeadings = [];
        layoutItems.forEach(container => {
            const headingsInContainer = container.querySelectorAll('h2, h3');
            allHeadings.push(...headingsInContainer);
        });

        allHeadings = [...new Set(allHeadings)];
     

        // Filter out headings that are inside the navigation component
        const headings = allHeadings.filter(heading => !nav.contains(heading));

        if (headings.length === 0) {
            console.warn('No H2/H3 headings found in content');
            nav.style.display = 'none';
            return;
        }

        // Generate anchor links for headings without IDs
        headings.forEach((heading, index) => {
            if (!heading.id) {
                const text = heading.textContent.trim();
                const id = text.toLowerCase()
                    .replace(/[^\w\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/--+/g, '-')
                    .trim();
                heading.id = id || `section-${index}`;
            }
        });

        // Build navigation menu
        let currentH2Item = null;
        headings.forEach((heading) => {
            const level = heading.tagName.toLowerCase();
            const text = heading.textContent.trim();
            const id = heading.id;

            if (level === 'h2') {
                const li = document.createElement('li');
                li.className = 'in-page-nav__item';

                const a = document.createElement('a');
                a.href = `#${id}`;
                a.className = 'in-page-nav__link';
                a.textContent = text;
                a.setAttribute('data-section', id);

                li.appendChild(a);
                navList.appendChild(li);
                currentH2Item = li;
            } else if (level === 'h3' && currentH2Item) {
                let sublist = currentH2Item.querySelector('.in-page-nav__sublist');
                if (!sublist) {
                    sublist = document.createElement('ul');
                    sublist.className = 'in-page-nav__sublist';
                    currentH2Item.appendChild(sublist);
                }

                const li = document.createElement('li');
                li.className = 'in-page-nav__subitem';

                const a = document.createElement('a');
                a.href = `#${id}`;
                a.className = 'in-page-nav__sublink';
                a.textContent = text;
                a.setAttribute('data-section', id);

                li.appendChild(a);
                sublist.appendChild(li);
            }
        });
        
        // Smooth scroll behavior using native browser smooth scroll
        const links = nav.querySelectorAll('a[href^="#"]');
        links.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const targetId = link.getAttribute('href').substring(1);
                const targetElement = document.getElementById(targetId);

                if (targetElement) {
                    // Calculate position with offset for fixed header
                    const headerOffset = 100;
                    const elementPosition = targetElement.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

                    // Use native smooth scroll
                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });

                    // Update active state after a short delay
                    setTimeout(() => {
                        links.forEach(l => l.classList.remove('current'));
                        link.classList.add('current');
                    }, 100);
                }
            });
        });

        // Scroll spy - highlight current section
        let isScrolling;
        function updateActiveLink() {
            clearTimeout(isScrolling);

            isScrolling = setTimeout(() => {
                const scrollPosition = window.scrollY + 100;
                let currentSection = null;

                // Find the current section based on scroll position
                headings.forEach((heading) => {
                    const section = heading;
                    const sectionTop = section.offsetTop;
                    const sectionBottom = sectionTop + section.offsetHeight;

                    if (scrollPosition >= sectionTop && scrollPosition < sectionBottom) {
                        currentSection = section.id;
                    }
                });

                // If no section is found, default to the first item
                if (!currentSection && headings.length > 0) {
                    currentSection = headings[0].id;
                }

                // Update active link
                links.forEach(link => {
                    const sectionId = link.getAttribute('data-section');
                    if (sectionId === currentSection) {
                        link.classList.add('current');
                        // Expand parent if it's a sublink
                        const parentItem = link.closest('.in-page-nav__item');
                        if (parentItem) {
                            const parentLink = parentItem.querySelector('.in-page-nav__link');
                            if (parentLink && !link.classList.contains('in-page-nav__link')) {
                                parentLink.classList.add('current');
                            }
                        }
                    } else {
                        link.classList.remove('current');
                    }
                });

                // Ensure at least one link is always active
                const hasActiveLink = Array.from(links).some(link => link.classList.contains('current'));

               if (!hasActiveLink && links.length > 0) {
                    links[0].classList.add('current');
                }
            }, 50);
        }

        window.addEventListener('scroll', updateActiveLink);
        updateActiveLink(); // Initial call
    });
</script>
