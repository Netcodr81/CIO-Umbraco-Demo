@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockListItem<ContentModels.SingleLink>>

@{
    if (Model is null)
        return;

    var content = Model.Content;

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    var linkUrl = content?.Link?.Url;
    var linkTarget = string.IsNullOrWhiteSpace(content?.Link?.Target) ? "_self" : content.Link.Target;
    var relAttr = linkTarget == "_blank" ? " rel=\"noopener noreferrer\"" : string.Empty;
    var accessibleName = !string.IsNullOrWhiteSpace(content?.Link?.Name) ? content.Link.Name : (linkUrl ?? "Link");
    var ariaAttr = !string.IsNullOrWhiteSpace(content?.Link?.Name) ? string.Empty : $" aria-label=\"{accessibleName}\"";
}

@if (!string.IsNullOrWhiteSpace(linkUrl))
{
    <a href="@linkUrl" class="cio-footer__link-item @blockClasses" target="@linkTarget"@Html.Raw(relAttr + ariaAttr)>
        @(content?.Link?.Name ?? linkUrl)
        @if (linkTarget == "_blank")
        {
            <span class="visually-hidden"> (opens in a new tab)</span>
        }
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M14 3v2h3.59l-9.83 9.83l1.41 1.41L19 6.41V10h2V3m-2 16H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7Z"></path>
        </svg>
    </a>
}
else
{
    <span class="cio-footer__link-item @blockClasses" aria-disabled="true">@accessibleName</span>
}
