@using System.Text.Json
@using CIOUmbracoDemo.Extensions
@using CIOUmbracoDemo.Views.Calendar.Models
@using Umbraco.Community.BlockPreview.Extensions
@using FullCalendarEvent = CIOUmbracoDemo.Views.Calendar.Models.FullCalendarEvent
@inherits UmbracoViewPage<BlockGridItem<ContentModels.Calendar>>

@{
    // This component relies on the Full Calendar javascript package. information on the package can be found here https://fullcalendar.io/docs
    if (Model.Content is null) return;

    var content = Model.Content;
    var calendarEvents = new List<FullCalendarEvent>();

    foreach(var @event in content.Events)
    {
        var calendarEvent = @event as BlockListItem<CalendarEvent>;

        calendarEvents.Add(new FullCalendarEvent
        {
            Title = calendarEvent?.Content?.Title,
            Start = calendarEvent?.Content?.Start?.ToString("yyyy-MM-ddTHH:mm:ss"),
            End = calendarEvent?.Content?.End?.ToString("yyyy-MM-ddTHH:mm:ss"),
            Color = calendarEvent?.Content?.EventColor?.Color ?? "#00607f",
            TextColor = "#ffffff",
            ExtendedProps = new EventDetails
            {
                Description = calendarEvent?.Content?.EventDetails,
                Location = calendarEvent?.Content?.EventLocation
            }
        });
    }
    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    var serializerOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = false
    };

    var serializedEvents = JsonSerializer.Serialize(calendarEvents, serializerOptions);

    var test = "";
}

@if (Context.Request.IsBlockPreviewRequest())
{
    <h1>Calendar Events</h1>

    <div style="display: flex; gap: 10px;">

    @foreach (var @event in content.Events)
    {
        @await Html.PartialAsync("/Views/Partials/blockgrid/Components/calendarEvent.cshtml", @event)
    }
    </div>
}
else
{
    <div class="calendar-container @blockClasses">
        <div id="calendar"></div>
        <!-- Event Popover Backdrop -->
        <div id="event-popover-backdrop" class="event-popover-backdrop" style="display: none;"></div>
        <!-- Event Popover (Calendar Card Style) -->
        <div id="event-popover" class="event-popover" style="display: none;">
            <button class="event-popover__close" aria-label="Close popover">&times;</button>
            <div class="event-popover__card">
                <div class="event-popover__content">
                    <!-- Date & Time Section -->
                    <div class="event-popover__datetime">
                        <div class="event-popover__date">
                            <span class="event-popover__month"></span>
                            <span class="event-popover__day"></span>
                        </div>
                        <div class="event-popover__time-range">
                            <div class="event-popover__time">
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                    <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm0 14.5a6.5 6.5 0 1 1 0-13 6.5 6.5 0 0 1 0 13z"/>
                                    <path d="M7.5 3v5l4.5 2.5.5-.9L8.5 7.5V3h-1z"/>
                                </svg>
                                <span class="event-popover__time-text"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Title -->
                    <h3 class="event-popover__title"></h3>

                    <!-- Details -->
                    <div class="event-popover__details">
                        <div class="event-popover__detail-item event-popover__location">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M8 0a5 5 0 0 0-5 5c0 3.25 5 11 5 11s5-7.75 5-11a5 5 0 0 0-5-5zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
                            </svg>
                            <span class="event-popover__location-text"></span>
                        </div>
                        
                        <div class="event-popover__detail-item event-popover__description">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M2 2h12v12H2V2zm1 1v10h10V3H3zm1 2h8v1H4V5zm0 2h8v1H4V7zm0 2h5v1H4V9z"/>
                            </svg>
                            <span class="event-popover__description-text"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


<script>
    document.addEventListener('DOMContentLoaded', function() {
    
        var calendarElement = document.getElementById('calendar');

        if (calendarElement) {
            var calendar = new FullCalendar.Calendar(calendarElement, {
                initialView: 'dayGridMonth',
                events: @Html.Raw(serializedEvents),
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                // Event display settings
                displayEventTime: false, // Hide time from event display
                displayEventEnd: false, // Hide end time
                eventDisplay: 'block', // Display as blocks instead of dots
                // Enable date clicking
                dateClick: function(info) {
                    console.log('Date clicked:', info.dateStr);
                },
                // Enable event clicking - show popover
                eventClick: function(info) {
                    info.jsEvent.preventDefault(); // Prevent navigation

                    var event = info.event;
                    var popover = document.getElementById('event-popover');

                    // Get event color
                    var eventColor = event.backgroundColor || event.color || '#00607f';

                    // Set date badge with event color
                    var dateElement = popover.querySelector('.event-popover__date');
                    if (event.start) {
                        var startDate = new Date(event.start);
                        popover.querySelector('.event-popover__month').textContent = startDate.toLocaleString('en-US', { month: 'short' }).toUpperCase();
                        popover.querySelector('.event-popover__day').textContent = startDate.toLocaleString('en-US', { day: '2-digit' });
                        // Set the background color for the date badge
                        dateElement.style.backgroundColor = eventColor;
                    }

                    // Set title
                    popover.querySelector('.event-popover__title').textContent = event.title;

                    // Format and set time
                    var timeText = popover.querySelector('.event-popover__time-text');
                    if (event.start) {
                        var startTime = event.start.toLocaleString('en-US', {
                            hour: event.allDay ? undefined : 'numeric',
                            minute: event.allDay ? undefined : '2-digit'
                        });
                        var endTime = event.end ? ' - ' + event.end.toLocaleString('en-US', {
                            hour: event.allDay ? undefined : 'numeric',
                            minute: event.allDay ? undefined : '2-digit'
                        }) : '';
                        timeText.textContent = startTime + endTime;
                    }

                    // Set location
                    var locationItem = popover.querySelector('.event-popover__location');
                    var locationText = popover.querySelector('.event-popover__location-text');
                    if (event.extendedProps && event.extendedProps.location) {
                        locationText.textContent = event.extendedProps.location;
                        locationItem.style.display = 'flex';
                    } else {
                        locationItem.style.display = 'none';
                    }

                   
                    // Set description
                    var descItem = popover.querySelector('.event-popover__description');
                    var descText = popover.querySelector('.event-popover__description-text');
                    if (event.extendedProps && event.extendedProps.description) {
                        descText.innerHTML = event.extendedProps.description;
                        descItem.style.display = 'flex';
                    } else {
                        descItem.style.display = 'none';
                    }

                    // Show popover (CSS handles centering)
                    var backdrop = document.getElementById('event-popover-backdrop');
                    backdrop.style.display = 'block';
                    popover.style.display = 'block';
                },
                // Styling
                height: 'auto',
                aspectRatio: 1.8
            });

            calendar.render();

            // Close popover when clicking the X button
            document.querySelector('.event-popover__close').addEventListener('click', function() {
                document.getElementById('event-popover').style.display = 'none';
                document.getElementById('event-popover-backdrop').style.display = 'none';
            });

            // Close popover when clicking backdrop
            document.getElementById('event-popover-backdrop').addEventListener('click', function() {
                document.getElementById('event-popover').style.display = 'none';
                document.getElementById('event-popover-backdrop').style.display = 'none';
            });

            calendar.getEvents();
        }
    });
</script>