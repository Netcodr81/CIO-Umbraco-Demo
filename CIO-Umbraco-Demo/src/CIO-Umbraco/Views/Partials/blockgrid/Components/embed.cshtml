@using CIOUmbracoDemo.Extensions
@inherits UmbracoViewPage<BlockGridItem<ContentModels.Embed>>

@{
    if (Model.Content is null) return;

    var content = Model.Content;

    var width = !string.IsNullOrWhiteSpace(content.Width) ? content.Width : "100%";
    var height = !string.IsNullOrWhiteSpace(content.Height) ? content.Height : "100%";
    var tabletWidth = !string.IsNullOrWhiteSpace(content.TabletWidth) ? content.TabletWidth : "100%";
    var tabletHeight = !string.IsNullOrWhiteSpace(content.TabletHeight) ? content.TabletHeight : "100%";
    var mobileWidth = !string.IsNullOrWhiteSpace(content.MobileWidth) ? content.MobileWidth : "100%";
    var mobileHeight = !string.IsNullOrWhiteSpace(content.MobileHeight) ? content.MobileHeight : "100%";

    var styles = $@"
        --embed__width: {width};
        --embed__height: {height};
        --embed__tablet-width: {tabletWidth};
        --embed__tablet-height: {tabletHeight};
        --embed__mobile-width: {mobileWidth};
        --embed__mobile-height: {mobileHeight};
    ";

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();
}

@{
    // Determine accessible title for the iframe. Prefer an explicit Title or Caption if available.
    var iframeTitle = !string.IsNullOrWhiteSpace(content?.Title) ? content.Title : (!string.IsNullOrWhiteSpace(content?.Caption) ? content.Caption : "Embedded content");
}

<div class="embed__container @blockClasses" style="@styles" role="region" aria-label="@iframeTitle">
    @if (string.IsNullOrWhiteSpace(content?.EmbedUrl))
    {
        <p class="visually-hidden">No embedded content available.</p>
    }
    else
    {
        <iframe
            src="@content.EmbedUrl"
            title="@iframeTitle"
            loading="lazy"
            role="document"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
            allowfullscreen
            style="width: 100%; height: 100%; border: 0;">
        </iframe>
    }
</div>
