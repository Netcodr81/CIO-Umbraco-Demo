@using System.Text
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@inherits UmbracoViewPage<BlockGridItem>

@{
    if (Model.Content is null)
    {
        return;
    }

    var content = Model.Content;

    var maxNumberOfButtonsPerRow = content.Value<string>("maxNumberOfCardsPerRow") ?? "3";

    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();

    var styles = new StringBuilder();

    var backgroundColor = content.Value<ColorPickerValueConverter.PickedColor>("backgroundColor")?.Color;

    if (backgroundColor is not null)
    {
        styles.Append($"background-color: {backgroundColor}");
    }

    var cards = content.Value<BlockListModel>("cards");
   
}

<div class="info-card-grid @blockClasses" data-columns="@maxNumberOfButtonsPerRow" style="@styles">


    @if (cards != null && cards.Any())
    {
        @foreach (var button in cards)
        {
            var cardToRender = button as BlockListItem;
            @await Html.PartialAsync("infoCard", cardToRender)
        }
    }

</div>