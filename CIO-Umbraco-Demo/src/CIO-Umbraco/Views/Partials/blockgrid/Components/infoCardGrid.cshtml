@using System.Text
@inherits UmbracoViewPage<BlockGridItem<ContentModels.InfoCardGrid>>

@{
    if (Model.Content is null)
    {
        return;
    }

    var content = Model.Content;

    var maxNumberOfButtonsPerRow = content.MaxNumberOfCardsPerRow ?? "3";
   
}

<div class="info-card-grid" data-columns="@maxNumberOfButtonsPerRow">


    @if (content.Cards.Any())
    {
        @foreach (var button in content.Cards)
        {
            var cardToRender = button as BlockListItem<InfoCard>;
            @await Html.PartialAsync("infoCard", cardToRender)
        }
    }

</div>