@using Umbraco.Community.BlockPreview.Extensions
@using Umbraco.Extensions
@inherits UmbracoViewPage<BlockGridItem>

@{
    if (Model?.Content is null) return;
    var content = Model.Content;

    // Read properties by alias to avoid compile-time dependency on generated models
    var anchorId = content.Value<string>("anchorId")?.Trim();
    var anchorLabel = !string.IsNullOrWhiteSpace(content.Value<string>("anchorLabel")) ? content.Value<string>("anchorLabel") : anchorId ?? "Anchor";
    var blockClasses = Model.Settings.GenerateBlockSettingsClasses();
}


@if (Context.Request.IsBlockPreviewRequest())
{
    <p>Anchor Id: @(content.Value<string>("anchorId")) (this will be hidden when rendered)</p>
}
else
{
    @* Render a focusable landmark for fragment links. Use tabindex="-1" so script can move focus here when navigating to the fragment. Do not set aria-hidden so assistive tech can land here. *@
    @if (!string.IsNullOrWhiteSpace(anchorId))
    {
        <div id="@anchorId" class="anchor__container @blockClasses" tabindex="-1" role="region" aria-label="@anchorLabel" data-anchor-id="@anchorId"></div>
    }
}
