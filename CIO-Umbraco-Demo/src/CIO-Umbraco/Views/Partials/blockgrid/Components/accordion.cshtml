@inherits UmbracoViewPage<BlockGridItem<Accordion>>

@{
	if (Model?.Content is null)
	{
		return;
	}

	var content = Model.Content;

	// Generate unique ID prefix for this accordion instance
	var uniqueId = Guid.NewGuid().ToString("N").Substring(0, 8);

	var tabColor = content?.TabColor?.Color ?? "#00607f";
	var tabHoverColor = content?.TabHoverColor?.Color ?? "#4b4c4e";
	var titleColor = content?.TitleColor?.Color ?? "#1b1b1b";
	var contentColor = content?.ContentColor?.Color ?? "#1b1b1b";
	var iconColor = content?.IconColor?.Color ?? "#000000";
	var iconBackgroundColor = content?.IconBackgroundColor?.Color ?? "#ffc44d";

	var cssVariables = $@"
		--accordion-tab-color: {tabColor};
		--accordion-tab-hover-color: {tabHoverColor};
		--accordion-title-color: {titleColor};
		--accordion-content-color: {contentColor};
		--accordion-icon-color: {iconColor};
		--accordion-icon-background-color: {iconBackgroundColor};
	";
}

@if (content.UseTabAccordion)
{
	<div class="accordion-tabs__container" style="@cssVariables">
		<div class="accordion-tabs__list" role="tablist">
			@for (int i = 0; i < content.Items!.Count; i++)
			{
				if (content.Items[i].Content is AccordionItem tabItem)
				{
					var tabId = $"tab-{i}";
					var panelId = $"tabpanel-{i}";
					<button class="accordion-tabs__tab" 
							id="@tabId" 
							role="tab" 
							aria-selected="@(i == 0 ? "true" : "false")" 
							aria-controls="@panelId"
							tabindex="@(i == 0 ? "0" : "-1")"
							type="button">
						@tabItem.DrawerTitle
					</button>
				}
			}
		</div>

		<div class="accordion-tabs__panels">
			@for (int i = 0; i < content.Items.Count; i++)
			{
				if (content.Items[i].Content is AccordionItem tabItem)
				{
					var tabId = $"tab-{i}";
					var panelId = $"tabpanel-{i}";
					<div class="accordion-tabs__panel @(i == 0 ? "tabs__panel--active" : "")"
						 id="@panelId" 
						 role="tabpanel" 
						 aria-labelledby="@tabId"
						 tabindex="0"
						 hidden="@(i != 0)">
						<div class="accordion-tabs__content">
							@tabItem.DrawerContent
						</div>
					</div>
				}
			}
		</div>
	</div>
}
else
{
	<div class="accordion__container" style="@cssVariables">
		
		@for(int i = 0; i < content?.Items?.Count; i++)
		{
			if(content.Items[i].Content is AccordionItem accordionItem)
			{
				var drawerId = $"drawer-{uniqueId}[{i}]";
				var buttonId = $"accordion-button-{uniqueId}[{i}]";
				<div class="accordion__item">
					<h3 class="accordion__heading">
						<button class="accordion__toggle" 
						        id="@buttonId" 
						        aria-expanded="false" 
						        aria-controls="@drawerId"
						        type="button">
							<span class="accordion__icon" aria-hidden="true"></span>
							<span class="accordion__title">@accordionItem.DrawerTitle</span>
						</button>
					</h3>

					<div class="accordion__drawer" id="@drawerId" aria-labelledby="@buttonId">
						<div class="accordion__content">
							@accordionItem.DrawerContent
						</div>
					</div>
				</div>
			}
		}
	</div>
}

