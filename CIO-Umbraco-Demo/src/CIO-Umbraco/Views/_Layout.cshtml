@using Umbraco.Forms.Web
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = null;
    var siteSettings = Model.Root().FirstChild<SiteSettings>();

    // Get per-page background color (optional page property)
    var pageBackgroundColor = Model.Value<string>("pageBackgroundColor") ?? "#f3f7fc";

    string styleAttribute = "";

    // Get the background image from pageSettingsBackgroundImagePicker
    var backgroundImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("pageSettingsBackgroundImagePicker");

    if (backgroundImage != null)
    {
        styleAttribute = $"background-image: url({backgroundImage.MediaUrl()});";
    }

    // Add CSS variable for page background
    styleAttribute += $"--page-bg:{pageBackgroundColor};background-color:var(--page-bg);";

    var theme = siteSettings?.Theme?.ToLower() ?? "blue";
}

<!doctype html>
<html lang="en" data-bs-theme="dark">
<head>
    <partial name="Head/_meta"/>
    <link href="~/css/layout.css" rel="stylesheet" asp-append-version="true"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.ico">
    <link rel="stylesheet" href="/css/styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/_content/NEOCIO.Umbraco.Components/css/component-styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/CIOUmbracoDemo.styles.css"/>
    <link rel="stylesheet" href="~/css/umbraco-forms.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true"/>
    <link rel="stylesheet" href="/css/custom-umbraco-theme.css" asp-append-version="true"/>

    <!-- FullCalendar CSS -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/index.global.min.css" rel="stylesheet"/>

    <!-- Start Google Fonts - Lato -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&display=swap" rel="stylesheet">

    <!-- Form Validation Scripts -->
    <script src="https://ajax.aspnetcdn.com/ajax/jQuery/jquery-3.0.0.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.19.2/jquery.validate.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/mvc/5.2.3/jquery.validate.unobtrusive.min.js"></script>

    <!-- End Google Fonts - Lato -->
</head>
<body class="theme-@theme" data-bgimage="@backgroundImage?.MediaUrl()" style="@styleAttribute">
<div id="page-top" class="anchor__container" aria-hidden="true" data-anchor-id="page-top"></div>
<div class="document d-flex flex-column justify-content-between">
    <!-- START BANNER -->
    @if (siteSettings?.ShowBanner ?? true)
    {
        @await Html.PartialAsync("layout/Banner")
    }
    <!-- END BANNER -->

    <!-- START HEADER -->
    @await Html.PartialAsync("layout/Header")
    <!-- END HEADER -->

    <main role="main" class="flex-grow-1 pb-3">
        @RenderBody()
    </main>

    <!-- START FOOTER -->
    @await Html.PartialAsync("layout/Footer")
    <!-- END FOOTER -->
</div>
<script src="/scripts/main.js" asp-append-version="true"></script>
<script src="/scripts/navigation.js" asp-append-version="true"></script>
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/index.global.min.js'></script>


</body>
</html>