
@using PickedColor = Umbraco.Cms.Core.PropertyEditors.ValueConverters.ColorPickerValueConverter.PickedColor
@using Umbraco.Extensions

@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = "_Layout.cshtml";
    var content = Model.Value<BlockGridModel>("contentGrid");

    var pageBg = Model.Value<PickedColor>("pageBackgroundColor")?.Color;
    var pageStyles = !string.IsNullOrWhiteSpace(pageBg) ? $"background-color:{pageBg}" : "background-color:#f3f7fc";
}

<!-- START - BLOCK GRID -->
@await Html.GetBlockGridHtmlAsync(content)

<!-- END - BLOCK GRID -->