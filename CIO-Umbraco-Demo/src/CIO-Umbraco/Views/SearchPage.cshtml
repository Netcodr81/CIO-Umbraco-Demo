@using CIOUmbracoDemo.Models
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = "_Layout.cshtml";
    var searchQuery = ViewData["SearchQuery"]?.ToString();
    var searchResults = ViewData["SearchResults"] as SearchResults;
}

<div class="container pt-6">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Search Results</h1>


            <p class="lead mb-2">Search query: <strong>@searchQuery</strong></p>

            @if (searchResults != null && searchResults.Items.Any())
            {
                <p class="text-muted mb-4">
                    Total results: @searchResults.TotalResults
                    (showing @((searchResults.CurrentPage - 1) * searchResults.PageSize + 1) - @Math.Min(searchResults.CurrentPage * searchResults.PageSize, searchResults.TotalResults))
                </p>

                <div class="search-results">
                    @foreach (var result in searchResults.Items)
                    {
                        var target = result.ContentType == ContentType.Media ? "_blank" : "_self";
                        <div class="border-bottom mb-4 pb-4">
                            <h3 class="h5 mb-2">
                                <a class="page-item" href="@result.Url" target="@target">@result.PageTitle</a>
                            </h3>

                            @if (!string.IsNullOrWhiteSpace(result.ContentGrid))
                            {
                                <p class="mb-2">
                                    @(result.ContentGrid.Length > 300
                                        ? result.ContentGrid.Substring(0, 300) + "..."
                                        : result.ContentGrid)
                                </p>
                            }

                            <p class="text-muted small mb-0">
                                <strong>Url:</strong> @result.Url
                            </p>
                        </div>
                    }
                </div>

                @if (searchResults.TotalResults > 0)
                {
                    <nav aria-label="Search results pagination" class="mt-4">
                        <ul class="pagination justify-content-center">
                            @* Previous button *@
                            <li class="page-item @(searchResults.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="?query=@Uri.EscapeDataString(searchQuery)&page=@(searchResults.CurrentPage - 1)" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>

                            @* Page numbers *@
                            @{
                                var startPage = Math.Max(1, searchResults.CurrentPage - 2);
                                var endPage = Math.Min(searchResults.TotalPages, searchResults.CurrentPage + 2);

                                // Show first page if not in range
                                if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?query=@Uri.EscapeDataString(searchQuery)&page=1">1</a>
                                    </li>
                                    if (startPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }

                                // Show page range
                                for (var i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == searchResults.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="?query=@Uri.EscapeDataString(searchQuery)&page=@i">@i</a>
                                    </li>
                                }

                                // Show last page if not in range
                                if (endPage < searchResults.TotalPages)
                                {
                                    if (endPage < searchResults.TotalPages - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }

                                    <li class="page-item">
                                        <a class="page-link" href="?query=@Uri.EscapeDataString(searchQuery)&page=@searchResults.TotalPages">@searchResults.TotalPages</a>
                                    </li>
                                }
                            }

                            @* Next button *@
                            <li class="page-item @(searchResults.CurrentPage == searchResults.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?query=@Uri.EscapeDataString(searchQuery)&page=@(searchResults.CurrentPage + 1)" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-info mt-4">
                    <p class="mb-0">No results found for "<strong>@searchQuery</strong>".</p>
                </div>
            }


        </div>
    </div>
</div>