    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "6ad953b0-67dd-414d-95ee-fa4e6a171720",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EHere are some of the commands you can use with Microsoft Narrator to make your testing faster and easier. If you are not familiar with the Narrator key, please read the Narrator quick start first.\u003C/p\u003E\u003Cp\u003EFor more commands or if one doesn\u2019t work, see this \u003Ca target=\u0022_blank\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022https://support.microsoft.com/en-us/windows/appendix-b-narrator-keyboard-commands-and-touch-gestures-8bdab3f4-b3e9-4554-7f28-8b15bd37410a\u0022 title=\u0022support.microsoft.com\u0022 type=\u0022external\u0022\u003ENarrator keyboard shortcuts Microsoft support page\u003C/a\u003E.\u003C/p\u003E"
          }
        }
      ]
    },
