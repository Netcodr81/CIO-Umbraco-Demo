    {
      "contentTypeKey": "a8790ec0-2c08-4153-8546-9c5ef4763691",
      "key": "a0ac9f97-b227-4008-87b5-9fc91437ea10",
      "values": [
        {
          "alias": "headerText",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What is Microsoft Narrator?"
        },
        {
          "alias": "headerTextColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "black",
            "value": "#000000"
          }
        }
      ]
    },
    {
      "contentTypeKey": "a8790ec0-2c08-4153-8546-9c5ef4763691",
      "key": "e8d4514d-0cd9-4534-8970-53f6cc51e32d",
      "values": [
        {
          "alias": "headerText",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Changing the Narrator voice and other settings"
        },
        {
          "alias": "headerTextColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "black",
            "value": "#000000"
          }
        }
      ]
    },
    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "57890331-b795-4f54-88f1-365f58e2cff2",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EIf you wish to change the voice that Narrator uses or a number of other settings, you can do that in the Narrator settings in the Settings app.\u003C/p\u003E\u003Cp\u003EFor commands to navigate using Narrator, take a look at the \u003Ca target=\u0022\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022/{localLink:c776cb6d-bf4e-4fcf-ad99-2212fa8a8a4a}\u0022 title=\u0022Narrator Keyboard Commands\u0022 type=\u0022document\u0022\u003ENarrator Keyboard Commands Reference.\u003C/a\u003E\u003C/p\u003E"
          }
        }
      ]
    }
  ],
