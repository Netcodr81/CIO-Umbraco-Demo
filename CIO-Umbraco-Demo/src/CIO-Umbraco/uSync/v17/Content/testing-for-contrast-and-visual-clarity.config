    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "5e6bd13b-4c3a-4527-a4de-473712764322",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EWhen testing a site or application\u0027s visual accessibility, there are a few items to keep in mind.\u003C/p\u003E"
          }
        }
      ]
    }
  ],
