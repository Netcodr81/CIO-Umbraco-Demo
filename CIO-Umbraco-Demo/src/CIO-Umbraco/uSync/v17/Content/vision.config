          "editorAlias": null,
          "segment": null,
          "value": "Our Vision of State Enterprise Technology"
        },
        {
          "alias": "backgroundColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        },
        {
