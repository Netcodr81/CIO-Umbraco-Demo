    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "7b9b1449-ca76-4310-b771-7a347649cbc6",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Ch2\u003EThe Office of the CIO Service Desk provides a single point of contact for the Office of the CIO\u003C/h2\u003E\u003Cp\u003EThis is primarily done by utilizing the State\u2019s Service Portal which allows for an efficient and effective flow of information between requestor and provider. Service Desk staff processes these requests using industry best standards and practices for service management. We work hard to ensure each request is handled as efficiently and effectively as possible.\u003C/p\u003E"
          }
        }
      ]
    },
