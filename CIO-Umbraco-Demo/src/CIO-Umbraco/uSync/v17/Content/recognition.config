    {
      "contentTypeKey": "48dda820-9e38-4caf-a7ec-a52a6a6020ad",
      "key": "5a429063-a92f-458d-a88a-2ae9e49ff702",
      "values": []
    },
    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "17faca88-83fe-4d6c-8623-e83e75c63054",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Ch2\u003ENebraskans value exceptional customer service.\u003C/h2\u003E\u003Cp\u003EPositive feedback about the work we do from those teammates with whom we directly work makes a positive difference to us.\u003C/p\u003E\u003Cp\u003EPlease consider nominating our teammates for special recognition for a job well done. Whether you are from a partnering State Agency or internal team, we want to hear from you!\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "0554dd37-9a89-402e-a8e9-f83312c283c1",
      "key": "5b5ed972-a1c6-4bd5-af85-334df74f0d2f",
      "values": [
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Make a nomination"
        },
        {
          "alias": "link",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "name": "cioapps.nebraska.gov",
              "target": "_blank",
              "unique": null,
              "type": null,
              "udi": null,
              "url": "https://cioapps.nebraska.gov/EmployeeRecognition/Account/Logon",
              "queryString": null
            }
          ]
        },
        {
          "alias": "buttonStyle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "Secondary"
          ]
        },
        {
          "alias": "icon",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "1c7de931-da50-4bed-8207-9bfe55b54494",
              "mediaKey": "f344cfad-cb0b-4df0-8a95-d7ef9d178c2f",
              "mediaTypeAlias": "umbracoMediaVectorGraphics",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "iconLocation",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "Append"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "7c7a983d-b011-445c-b7a1-ffa8880b16f4",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003ENominations are evaluated by the OCIO leadership team, with the following criteria; the team and/or teammate:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003Emet or exceeded aspirations\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003Eprovided exceptional service\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003Enotably built mutual respect across teams\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003Eprovided an innovation technology solution\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003ETo make a nomination, visit the \u003Ca target=\u0022_blank\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022https://cioapps.nebraska.gov/EmployeeRecognition/Account/Logon\u0022 title=\u0022cioapps.nebraska.gov\u0022 type=\u0022external\u0022\u003EOCIO\u2019s Champion Award Application\u003C/a\u003E.\u003C/p\u003E\u003Cp\u003EYou may use your first.last credentials to log in or create a new nomination as a guest.\u003C/p\u003E\u003Cp\u003EThank you again for taking the time to recognize your IT teammates, the tireless people behind the scenes, making the things we do more efficient, effective and customer focused.\u003C/p\u003E"
          }
        }
      ]
    },
    {
