    {
      "contentTypeKey": "a8790ec0-2c08-4153-8546-9c5ef4763691",
      "key": "78b81553-86b9-4500-9f9d-8b334cdac387",
      "values": [
        {
          "alias": "headerText",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Accessibility Audit Checklist"
        },
        {
          "alias": "headerTextColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "black",
            "value": "#000000"
          }
        },
        {
          "alias": "headerAccentColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "secondary-medium",
            "value": "#FFC44D"
          }
        },
        {
          "alias": "headerMarginBottom",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        }
      ]
    },
    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "ff565f86-00da-4d96-83c1-14995ad73f9d",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003ETo start the testing process, \u003Cstrong\u003Edownload \u003C/strong\u003Ethe \u003Cstrong\u003EAccessibility Audit Checklist spreadsheet\u003C/strong\u003E. This tool will help you evaluate Keyboard Testing, Visual Testing, and Non-Visual Testing. The second sheet of the spreadsheet contains a detailed starter guide with instructions. Those instructions are replicated on this page as well.\u003C/p\u003E\u003Cp\u003E\u003Ca target=\u0022_blank\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022https://sower-media.nebraska.gov/content/dam/ocio/documents/Accessibility%20Audit%20Checklist%20Template.xlsx\u0022 title=\u0022sower-media.nebraska.gov\u0022 type=\u0022external\u0022\u003EDownload the Accessibility Audit Checklist spreadsheet\u003C/a\u003E\u003C/p\u003E"
          }
        }
      ]
    },
    {
