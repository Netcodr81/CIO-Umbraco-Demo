    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "54e3cb8e-7e61-422c-aa9a-18636439d798",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe OCIO Digital Accessibility team has all the resources to assist you with both Non-Visual and Visual Testing, so please feel free to reach out. If you have any questions or concerns about Accessibility Testing, don\u2019t hesitate to contact us at \u003Ca target=\u0022_blank\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022mailto:OCIO.DigitalAccessibility@nebraska.gov\u0022 title=\u0022mailto:OCIO.DigitalAccessibility@nebraska.gov\u0022 type=\u0022external\u0022\u003EOCIO.DigitalAccessibility@nebraska.gov\u003C/a\u003E or open a request on the Service Portal at \u003Ca target=\u0022_blank\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022https://serviceportal.ne.gov/\u0022 title=\u0022https://serviceportal.ne.gov/\u0022 type=\u0022external\u0022\u003Ehttps://serviceportal.ne.gov/\u003C/a\u003E\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "a8790ec0-2c08-4153-8546-9c5ef4763691",
      "key": "8b45602f-02ed-4b44-8555-6ce7a6217c15",
      "values": [
        {
          "alias": "headerText",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Visual Tests"
        },
        {
          "alias": "headerTextColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "black",
            "value": "#000000"
          }
        },
        {
          "alias": "headerAccentColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "secondary-medium",
            "value": "#FFC44D"
          }
        },
        {
          "alias": "headerMarginBottom",
          "culture": null,
          "editorAlias": null,
