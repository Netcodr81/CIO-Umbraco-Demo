    },
    {
      "contentTypeKey": "48dda820-9e38-4caf-a7ec-a52a6a6020ad",
      "key": "0cfd1158-da18-4f91-ad25-3ca91feae008",
      "values": []
    },
    {
      "contentTypeKey": "b87dee17-4242-4d83-9f36-63aae1204d93",
      "key": "012fe799-9379-4186-ae0d-06b5ff2a59be",
      "values": [
        {
          "alias": "content",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Ch2\u003EFrequently Asked Questions\u003C/h2\u003E\u003Ch3\u003EMultifactor Authentication\u003C/h3\u003E\u003Cp\u003E\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "160b16b9-b63a-4f04-b66f-138e6eed9e8c",
      "key": "b4fd2164-08fc-4067-9b5a-89fcee00a5cc",
      "values": [
        {
          "alias": "items",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "6391db4e-cf8c-4cf0-8a01-4ecae5694ddd",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "What is MFA (Multifactor Authentication) and why should I set up a new account now?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EMFA is everywhere you look across the modern digital landscape. Its purpose is to safeguard information stored within secured databases and systems. By using multiple factors to verify your identity, we reduce the risks that are associated with having compromised accounts.\u003C/p\u003E\u003Cp\u003EMFA is \u201Csomething you know\u201D (ie: your security questions) or \u201Csomething you have\u201D (this could be anything from a hard token to a push notification from a mobile device, to a rotating \u2018soft token\u2019 six digit code from your phone).\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "4fb9ee64-1bec-446b-af5c-4b58e54623ee",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Do I need to set this up on all my workstations?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EYou only need to set up your cloud account once, successfully. The beauty of the cloud is that you can take it anywhere with you, everywhere you go!\u003C/p\u003E\u003Cp\u003ESetup is easiest when you have access to Wi-Fi, a laptop or desktop computer, and you will need your phone. *Your phone will need to have the Microsoft Authenticator app installed.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "44e5e049-c3a5-4200-88e2-05d37f608409",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "How would I know if I am an MFA user?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EDo you work from home, or do you access our network from a remote office? MFA software is most likely required for you. When signing into the Virtual Private Network (VPN) for example, MFA will require you to provide two or more forms of identification for access to the system, this will include your username and password, plus one other authentication factor.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "6f5b73bb-1351-4d14-9e1c-de0d1bb036c3",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Can I use a personal mobile device for MFA authorization?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EIt is fine to use personal phones. The app does not use any identifiable information. By default, a push notification will send you an Approval button that you are signing in somewhere. You can deny if you did not sign into anything. That\u2019s all it does.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "a4a2e74b-dd4c-4daa-82e8-107f9c084baa",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "I already use MFA, why should I set up a \u0027cloud\u0027 account now?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EIf you already had MFA set up before January 2021, you still need to set up your new cloud account now. Prior to 2021, accounts were set up in a different environment which will be decommissioned on May 10th ending MFA access for those accounts. If you work remote in any capacity, you can switch to your cloud account seamlessly by setting up your cloud MFA account via your My Sign Ins page.\u003C/p\u003E\u003Cp\u003EMy Sign Ins uses cloud-based software, and you only need to set up your cloud account once to be able use it going forward from May 10th. By setting up your cloud account prior to May 10th, you ensure that you access to network tools continues after the May 10th cloud migration.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "c55cc692-fab9-47ad-bf0f-5a6236046af9",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "When do I start using My Sign Ins and stop using the MFA User Portal?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EStarting on May 10, 2021 you should be managing your MFA Mobile account from My Sign Ins.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "0d0b1bac-936b-4be5-b700-61762b06e439",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Will the Authentication App work on more than one mobile device?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EYes. You can install the Authenticator app on any smart mobile device. Once linked to your work account you will receive push notifications unless you change your default settings.\u003C/p\u003E\u003Cp\u003ELogin to your My Sign Ins account to make changes.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "71aea8fe-2d00-4381-8e66-d071051ff724",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Is this going to lock me out of my phone?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EYour personal device will function the same as it does today. This service does not require you to have Mobile Device Management which is the technology that secures the data on your phone.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "e92786db-0509-4e11-9ced-78193c87e960",
                "values": [
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Can I use my mobile device without installing the Authentication App?"
                  },
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EYes. You can choose to receive a text message with a one-time-passcode or token. Just select the Phone \u2013 Text option when setting up your account. When you are prompted for the one-time-passcode on the system, you will receive a text message with the code. Login to your My Sign Ins account to make changes.\u003C/p\u003E"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "3a05d613-3ab3-4151-8e31-0e75bb329b07",
                "values": [
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EIf you have a hard token, you should call the OCIO Service Desk or send us a service request through the OCIO website. In your request, include the serial number from the token\u2019s label (not the rotating number). By taking this step you are setting up an appointment with OCIO support, and someone will be in touch with you to update your device before the upgrade.\u003C/p\u003E\u003Cp\u003EWhile you do not need to setup your Cloud account on your mobile device, you may still do so if you have a smart phone.\u003C/p\u003E"
                    }
                  },
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "I use an MFA Hard Token, do I need to set this up?"
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "f363d702-c7b8-48e5-9e0f-a7b6bdfcfca9",
                "values": [
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003EWe highly recommend establishing a policy in your organization that anyone who is using VPN needs to set up an MFA account.\u003C/p\u003E"
                    }
                  },
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "I have VPN with Single Factor, does this apply to me?"
                  }
                ]
              },
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
                "key": "52881528-db0c-4d36-8f0c-6043159925d7",
                "values": [
                  {
                    "alias": "drawerContent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "Layout": {}
                      },
                      "markup": "\u003Cp\u003ESingle Factor is not a part of this project currently. Look for more details to come after this project is done on that specific topic and others.\u003C/p\u003E"
                    }
                  },
                  {
                    "alias": "drawerTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Will this project force our VPN users to use MFA?"
                  }
                ]
              }
            ],
            "settingsData": [
              {
                "contentTypeKey": "d8d8f061-79f9-4dcd-ad26-b4f8396712bc",
